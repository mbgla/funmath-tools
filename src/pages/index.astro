---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const tools = [
  { id: 'random-number', emoji: '🎲', gradient: 'from-blue-400 to-indigo-600' },
  { id: 'dice', emoji: '🎯', gradient: 'from-red-400 to-pink-600' },
  { id: 'coin-flip', emoji: '🪙', gradient: 'from-yellow-400 to-orange-500' },
  { id: 'spinner', emoji: '🎡', gradient: 'from-pink-400 to-purple-600' },
  { id: 'times-tables', emoji: '✖️', gradient: 'from-green-400 to-emerald-600' },
  { id: 'percentage', emoji: '%', gradient: 'from-teal-400 to-cyan-600' },
  { id: 'stopwatch', emoji: '⏱️', gradient: 'from-purple-400 to-fuchsia-600' },
  { id: 'unit-converter', emoji: '📐', gradient: 'from-cyan-400 to-teal-600' },
];

const games = [
  { id: 'quick-math', emoji: '⚡', gradient: 'from-amber-400 to-orange-600', name: 'Quick Math Challenge', desc: '60-second mental math race.' },
  { id: 'math-memory', emoji: '🧠', gradient: 'from-violet-400 to-purple-600', name: 'Math Memory Match', desc: 'Match equations with their answers.' },
  { id: 'tug-of-war', emoji: '⚔️', gradient: 'from-blue-500 to-red-500', name: 'Tug of War Math', desc: '2-player math battle. First to 5 wins!' },
  { id: '2048-math', emoji: '🎯', gradient: 'from-yellow-500 to-red-500', name: '2048 Math', desc: 'Combine tiles to reach 2048!' },
  { id: 'math-bingo', emoji: '🎰', gradient: 'from-green-500 to-teal-500', name: 'Math Bingo', desc: 'Classic bingo with math equations.' },
  { id: 'equation-balance', emoji: '⚖️', gradient: 'from-indigo-500 to-blue-600', name: 'Equation Balance', desc: 'Balance both sides of the equation.' },
  { id: 'math-snake', emoji: '🐍', gradient: 'from-emerald-400 to-green-600', name: 'Math Snake', desc: 'Classic Snake — eat the right answer!' },
  { id: 'math-tic-tac-toe', emoji: '⭕', gradient: 'from-cyan-500 to-blue-600', name: 'Math Tic-Tac-Toe', desc: '2-player or vs AI strategy game.' },
];
---

<BaseLayout>
  <section class="text-center py-10">
    <div class="inline-block mb-4 px-4 py-1 bg-brand-100 text-brand-700 rounded-full text-sm font-medium">
      ✨ 100% Free · Tools & Games · No Signup
    </div>
    <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-4 leading-tight">
      {t('home.hero.title' as any)}
    </h1>
    <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto mb-8">
      {t('home.hero.subtitle' as any)}
    </p>
    <div class="flex gap-3 justify-center flex-wrap">
      <a href="#tools" class="inline-block bg-gradient-to-r from-brand-500 to-brand-600 text-white px-7 py-3 rounded-full font-bold shadow-lg shadow-brand-500/30 hover:shadow-xl hover:scale-105 transition">
        🛠️ Tools
      </a>
      <a href="#games" class="inline-block bg-gradient-to-r from-pink-500 to-purple-600 text-white px-7 py-3 rounded-full font-bold shadow-lg shadow-pink-500/30 hover:shadow-xl hover:scale-105 transition">
        🎮 Games
      </a>
    </div>
  </section>

  <section id="tools" class="mt-12 scroll-mt-20">
    <div class="flex items-center gap-3 mb-6">
      <span class="text-3xl">🛠️</span>
      <div>
        <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900">Math Tools</h2>
        <p class="text-sm text-slate-600">Practical tools for teachers and students.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {tools.map(tool => {
        const href = getLocalizedPath(`/tools/${tool.id}`, lang);
        return (
          <a href={href} class="block rounded-2xl p-6 transition group relative overflow-hidden bg-white hover:-translate-y-1 hover:shadow-xl shadow-md cursor-pointer">
            <div class:list={['w-14 h-14 rounded-2xl flex items-center justify-center text-3xl mb-4 bg-gradient-to-br text-white font-black', tool.gradient]}>
              {tool.emoji}
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-1">{t(`tool.${tool.id}.name` as any)}</h3>
            <p class="text-sm text-slate-600">{t(`tool.${tool.id}.desc` as any)}</p>
            <div class="mt-4 text-brand-500 font-semibold text-sm group-hover:translate-x-1 transition">Try it →</div>
          </a>
        );
      })}
    </div>
  </section>

  <section id="games" class="mt-16 scroll-mt-20">
    <div class="flex items-center gap-3 mb-6">
      <span class="text-3xl">🎮</span>
      <div>
        <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900">Math Games</h2>
        <p class="text-sm text-slate-600">Fun games to practice math skills.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {games.map(game => {
        const href = game.soon ? '#' : getLocalizedPath(`/games/${game.id}`, lang);
        const Tag = game.soon ? 'div' : 'a';
        return (
          <Tag 
            href={!game.soon ? href : undefined}
            class:list={[
              'block rounded-2xl p-6 transition group relative overflow-hidden',
              game.soon ? 'bg-slate-100 opacity-70 cursor-not-allowed' : 'bg-white hover:-translate-y-1 hover:shadow-xl shadow-md cursor-pointer'
            ]}
          >
            {game.soon && (
              <span class="absolute top-3 end-3 text-[10px] font-bold bg-slate-600 text-white px-2 py-0.5 rounded-full">SOON</span>
            )}
            <div class:list={['w-14 h-14 rounded-2xl flex items-center justify-center text-3xl mb-4 bg-gradient-to-br text-white font-black', game.gradient]}>
              {game.emoji}
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-1">{game.name}</h3>
            <p class="text-sm text-slate-600">{game.desc}</p>
            {!game.soon && (
              <div class="mt-4 text-pink-500 font-semibold text-sm group-hover:translate-x-1 transition">Play now →</div>
            )}
          </Tag>
        );
      })}
    </div>
  </section>

  <section class="mt-20 max-w-3xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-4">Why FunMath Tools?</h2>
    <div class="grid md:grid-cols-3 gap-6 mt-8 text-start">
      <div class="p-4">
        <div class="text-3xl mb-2">🎓</div>
        <h3 class="font-bold mb-1">For Teachers</h3>
        <p class="text-sm text-slate-600">Classroom-ready tools and games that engage students.</p>
      </div>
      <div class="p-4">
        <div class="text-3xl mb-2">🏠</div>
        <h3 class="font-bold mb-1">For Parents</h3>
        <p class="text-sm text-slate-600">Support homeschooling with fun, interactive math.</p>
      </div>
      <div class="p-4">
        <div class="text-3xl mb-2">📱</div>
        <h3 class="font-bold mb-1">Any Device</h3>
        <p class="text-sm text-slate-600">Works on phones, tablets, and classroom screens.</p>
      </div>
    </div>
  </section>
</BaseLayout>
