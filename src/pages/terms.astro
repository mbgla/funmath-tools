---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const content = {
  en: {
    title: 'Terms of Service', updated: 'Last updated: April 2026',
    intro: 'Welcome to FunMath Tools. By using our website, you agree to these Terms of Service.',
    s: [
      { title: '1. Acceptance', text: 'By accessing FunMath Tools, you agree to be bound by these terms.' },
      { title: '2. Permitted Use', text: 'You may use our tools and games for personal, educational, and classroom purposes. You may share links to our website.' },
      { title: '3. Prohibited Use', text: 'You may not copy or redistribute our content commercially, use automated scraping tools, or attempt to disrupt website security.' },
      { title: '4. Intellectual Property', text: 'All content on FunMath Tools is our property. Educational classroom use is freely permitted.' },
      { title: '5. Disclaimer', text: 'FunMath Tools is provided "as is" without warranties. We strive for accuracy but cannot guarantee error-free content.' },
      { title: '6. Contact', text: 'Questions? Contact us at contact@funmath.tools' },
    ],
  },
  ar: {
    title: 'شروط الاستخدام', updated: 'آخر تحديث: أبريل 2026',
    intro: 'مرحباً بكم في فن-ماث تولز. باستخدام موقعنا، فإنكم توافقون على شروط الاستخدام هذه.',
    s: [
      { title: '١. القبول', text: 'بالوصول إلى فن-ماث تولز، توافق على الالتزام بهذه الشروط.' },
      { title: '٢. الاستخدام المسموح', text: 'يمكنك استخدام أدواتنا وألعابنا للأغراض الشخصية والتعليمية والفصول الدراسية. يمكنك مشاركة روابط موقعنا.' },
      { title: '٣. الاستخدام المحظور', text: 'لا يجوز نسخ أو إعادة توزيع محتوانا تجارياً، أو استخدام أدوات الاستخراج الآلي، أو محاولة تعطيل أمان الموقع.' },
      { title: '٤. الملكية الفكرية', text: 'جميع محتويات فن-ماث تولز ملكنا. الاستخدام التعليمي في الفصول مسموح به مجاناً.' },
      { title: '٥. إخلاء المسؤولية', text: 'يُقدَّم فن-ماث تولز "كما هو" دون ضمانات. نسعى للدقة لكن لا نضمن محتوى خالياً من الأخطاء.' },
      { title: '٦. التواصل', text: 'أسئلة؟ تواصل معنا على contact@funmath.tools' },
    ],
  },
  fr: {
    title: 'Conditions d\'Utilisation', updated: 'Dernière mise à jour: Avril 2026',
    intro: 'Bienvenue sur FunMath Tools. En utilisant notre site, vous acceptez ces Conditions d\'Utilisation.',
    s: [
      { title: '1. Acceptation', text: 'En accédant à FunMath Tools, vous acceptez d\'être lié par ces conditions.' },
      { title: '2. Utilisation Permise', text: 'Vous pouvez utiliser nos outils et jeux à des fins personnelles, éducatives et scolaires.' },
      { title: '3. Utilisation Interdite', text: 'Vous ne pouvez pas copier ou redistribuer notre contenu commercialement, utiliser des outils de scraping automatiques.' },
      { title: '4. Propriété Intellectuelle', text: 'Tout le contenu de FunMath Tools est notre propriété. L\'utilisation éducative en classe est librement autorisée.' },
      { title: '5. Avertissement', text: 'FunMath Tools est fourni "tel quel" sans garanties. Nous nous efforçons d\'être précis mais ne pouvons garantir un contenu sans erreur.' },
      { title: '6. Contact', text: 'Questions? Contactez-nous à contact@funmath.tools' },
    ],
  },
};

const c = content[lang as keyof typeof content] || content.en;
---

<BaseLayout title={`${c.title} — FunMath Tools`} description={c.intro}>
  <div class="max-w-3xl mx-auto py-8">
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-brand-500">{t('nav.home' as any)}</a>
      <span class="mx-2">/</span>
      <span>{c.title}</span>
    </nav>

    <h1 class="text-4xl font-extrabold text-slate-900 mb-2">{c.title}</h1>
    <p class="text-slate-500 mb-8">{c.updated}</p>

    <div class="bg-white rounded-3xl shadow-lg p-8 space-y-6">
      <p class="text-slate-700">{c.intro}</p>
      {c.s.map(section => (
        <section>
          <h2 class="text-xl font-bold mb-2 text-slate-900">{section.title}</h2>
          <p class="text-slate-700">{section.text}</p>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
