---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Terms of Service — FunMath Tools';
const description = 'Terms of service for using FunMath Tools website.';
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto py-8">
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2">/</span>
      <span>Terms of Service</span>
    </nav>

    <h1 class="text-4xl font-extrabold text-slate-900 mb-2">Terms of Service</h1>
    <p class="text-slate-500 mb-8">Last updated: April 2026</p>

    <div class="bg-white rounded-3xl shadow-lg p-8 prose prose-slate max-w-none">
      <p class="text-slate-700">
        Welcome to FunMath Tools. By using our website, you agree to these Terms of Service.
      </p>

      <h2 class="text-2xl font-bold mt-8 mb-3">1. Acceptance of Terms</h2>
      <p class="text-slate-700">
        By accessing FunMath Tools, you agree to be bound by these terms. If you don't agree, please don't use the site.
      </p>

      <h2 class="text-2xl font-bold mt-8 mb-3">2. Use of Service</h2>
      <p class="text-slate-700 mb-3">FunMath Tools is provided free of charge. You may:</p>
      <ul class="space-y-2 text-slate-700">
        <li>Use our tools and games for personal, educational, and classroom purposes</li>
        <li>Share links to our website</li>
        <li>Use our content with proper attribution for non-commercial educational purposes</li>
      </ul>

      <h2 class="text-2xl font-bold mt-8 mb-3">3. Prohibited Use</h2>
      <p class="text-slate-700 mb-3">You may not:</p>
      <ul class="space-y-2 text-slate-700">
        <li>Copy, modify, or redistribute our content commercially without permission</li>
        <li>Use automated tools to scrape or abuse our services</li>
        <li>Attempt to disrupt or compromise the website's security</li>
        <li>Use our service for any illegal purpose</li>
      </ul>

      <h2 class="text-2xl font-bold mt-8 mb-3">4. Intellectual Property</h2>
      <p class="text-slate-700">
        All content on FunMath Tools, including games, tools, designs, and code, is the property of FunMath Tools unless otherwise stated. Educational use in classrooms is freely permitted.
      </p>

      <h2 class="text-2xl font-bold mt-8 mb-3">5. Disclaimer</h2>
      <p class="text-slate-700">
        FunMath Tools is provided "as is" without warranties of any kind. While we strive for accuracy, we don't guarantee that all content is error-free or always available.
      </p>

      <h2 class="text-2xl font-bold mt-8 mb-3">6. Limitation of Liability</h2>
      <p class="text-slate-700">
        FunMath Tools and its operators are not liable for any damages arising from the use or inability to use this website.
      </p>

      <h2 class="text-2xl font-bold mt-8 mb-3">7. Third-Party Content</h2>
      <p class="text-slate-700">
        Our site may contain ads from third parties (such as Google AdSense). We are not responsible for the content or practices of third-party advertisers.
      </p>

      <h2 class="text-2xl font-bold mt-8 mb-3">8. Changes to Terms</h2>
      <p class="text-slate-700">
        We may update these Terms at any time. Continued use after changes means you accept the new Terms.
      </p>

      <h2 class="text-2xl font-bold mt-8 mb-3">9. Contact</h2>
      <p class="text-slate-700">
        Questions? Contact us at <a href="mailto:contact@funmath.tools" class="text-brand-500 hover:underline">contact@funmath.tools</a>
      </p>
    </div>
  </div>
</BaseLayout>
