---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const title = 'Tug of War Math — 2 Player Math Battle | FunMath Tools';
const description = 'Free 2-player tug of war math game. Solve equations to pull the rope! Play vs a friend or vs the computer robot.';
---

<BaseLayout title={title} description={description}>
  <nav class="text-sm text-slate-500 mb-4">
    <a href="/" class="hover:text-brand-500">Home</a>
    <span class="mx-2">/</span>
    <a href="/#games" class="hover:text-brand-500">Games</a>
    <span class="mx-2">/</span>
    <span>Tug of War Math</span>
  </nav>

  <div class="text-center mb-6">
    <div class="inline-flex w-20 h-20 rounded-3xl bg-gradient-to-br from-blue-600 to-red-600 items-center justify-center text-5xl mb-4">⚔️</div>
    <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-3">Tug of War Math</h1>
    <p class="text-slate-600 max-w-xl mx-auto">Solve equations to pull the rope! First to win the match takes the championship.</p>
  </div>

  <!-- Setup -->
  <div id="setupScreen" class="max-w-2xl mx-auto bg-white rounded-3xl shadow-xl p-6 md:p-8">
    <h2 class="font-bold text-lg text-slate-800 mb-4 text-center">Game Mode</h2>
    <div class="grid grid-cols-2 gap-3 mb-6">
      <button class="mode-btn p-4 rounded-2xl font-bold border-2 border-slate-200 hover:border-blue-500 transition" data-mode="2p" data-active="true">
        <div class="text-3xl mb-1">👥</div>
        <div>2 Players</div>
        <div class="text-xs text-slate-500 font-normal">Same device</div>
      </button>
      <button class="mode-btn p-4 rounded-2xl font-bold border-2 border-slate-200 hover:border-blue-500 transition" data-mode="cpu">
        <div class="text-3xl mb-1">🤖</div>
        <div>vs Robot</div>
        <div class="text-xs text-slate-500 font-normal">Beat the AI</div>
      </button>
    </div>

    <h2 class="font-bold text-lg text-slate-800 mb-4 text-center">Difficulty</h2>
    <div class="grid grid-cols-3 gap-3 mb-6">
      <button class="diff-btn p-3 rounded-2xl font-bold border-2 border-slate-200 hover:border-blue-500 transition text-sm" data-diff="easy" data-active="true">
        <div class="text-xl mb-1">🌱</div>Easy<div class="text-xs text-slate-400">+, −</div>
      </button>
      <button class="diff-btn p-3 rounded-2xl font-bold border-2 border-slate-200 hover:border-blue-500 transition text-sm" data-diff="medium">
        <div class="text-xl mb-1">🔥</div>Medium<div class="text-xs text-slate-400">+, −, ×</div>
      </button>
      <button class="diff-btn p-3 rounded-2xl font-bold border-2 border-slate-200 hover:border-blue-500 transition text-sm" data-diff="hard">
        <div class="text-xl mb-1">⚡</div>Hard<div class="text-xs text-slate-400">All ops</div>
      </button>
    </div>

    <h2 class="font-bold text-lg text-slate-800 mb-4 text-center">First to how many?</h2>
    <div class="grid grid-cols-3 gap-3 mb-6">
      <button class="win-btn py-3 rounded-xl font-bold border-2 border-slate-200 hover:border-blue-500 transition" data-win="3">3 pulls</button>
      <button class="win-btn py-3 rounded-xl font-bold border-2 border-slate-200 hover:border-blue-500 transition" data-win="5" data-active="true">5 pulls</button>
      <button class="win-btn py-3 rounded-xl font-bold border-2 border-slate-200 hover:border-blue-500 transition" data-win="7">7 pulls</button>
    </div>

    <button id="startBtn" class="w-full py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-blue-600 to-red-600 text-white shadow-lg active:scale-95 transition">
      ⚔️ Start Battle
    </button>
  </div>

  <!-- Game -->
  <div id="gameScreen" class="hidden max-w-5xl mx-auto">
    <!-- Score -->
    <div class="bg-white rounded-2xl shadow p-3 mb-4 flex items-center justify-between">
      <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white px-4 py-2 rounded-xl font-bold flex items-center gap-2">
        <span>🔵</span><span id="p1Name">Blue</span><span id="p1Score" class="text-2xl ms-2">0</span>
      </div>
      <div class="text-slate-500 text-xs font-bold text-center">
        <div>First to</div>
        <div id="winScoreDisplay" class="text-xl font-black text-slate-700">5</div>
        <div>pulls</div>
      </div>
      <div class="bg-gradient-to-r from-red-600 to-red-700 text-white px-4 py-2 rounded-xl font-bold flex items-center gap-2">
        <span id="p2Score" class="text-2xl me-2">0</span><span id="p2Name">Red</span><span>🔴</span>
      </div>
    </div>

    <!-- Animation Stage: centered cartoon characters like screenshot -->
    <div id="stage" class="bg-gradient-to-b from-sky-200 to-sky-100 rounded-3xl shadow-xl mb-4 relative overflow-hidden" style="height: 200px;">
      <!-- Sky background -->
      <div class="absolute inset-0" style="background: linear-gradient(180deg, #87CEEB 0%, #E0F0FF 70%, #C8B560 70%, #A0854A 100%);"></div>

      <!-- Center line -->
      <div class="absolute top-0 bottom-0" style="left: 50%; width: 2px; background: repeating-linear-gradient(to bottom, #dc2626 0px, #dc2626 8px, transparent 8px, transparent 16px); transform: translateX(-50%); z-index: 5;"></div>
      <!-- Center flag -->
      <div class="absolute" style="left: calc(50% - 6px); top: 8px; z-index: 6;">
        <div style="width: 2px; height: 30px; background: #1e293b; margin: 0 auto;"></div>
        <div style="width: 20px; height: 12px; background: #dc2626; margin-top: -30px; margin-left: 2px;"></div>
      </div>

      <!-- Win zones -->
      <div class="absolute top-0 bottom-8 left-0 w-16 bg-blue-500 opacity-20 rounded-l-3xl"></div>
      <div class="absolute top-0 bottom-8 right-0 w-16 bg-red-500 opacity-20 rounded-r-3xl"></div>
      <div class="absolute bottom-8 left-2 text-blue-700 font-black text-xs opacity-60">WIN</div>
      <div class="absolute bottom-8 right-2 text-red-700 font-black text-xs opacity-60">WIN</div>

      <!-- SVG Characters + Rope -->
      <svg id="gameCanvas" style="position:absolute;inset:0;width:100%;height:100%;z-index:10;" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
        <!-- Rope (extends far) -->
        <rect id="rope" x="-100" y="145" width="1000" height="7" fill="#c2410c" rx="3"/>
        <rect id="rope2" x="-100" y="147" width="1000" height="2" fill="#7c2d12" rx="1" opacity="0.5"/>

        <!-- Rope Marker (center) -->
        <circle id="ropeMarker" cx="400" cy="149" r="7" fill="#dc2626" stroke="white" stroke-width="2"/>

        <!-- BLUE TEAM - 2 characters pulling rope to the left -->
        <g id="blueTeam">
          <!-- Character 1 (front) -->
          <g id="blue1">
            <!-- Shadow -->
            <ellipse cx="195" cy="185" rx="22" ry="4" fill="#000" opacity="0.15"/>
            <!-- Legs -->
            <rect x="183" y="155" width="8" height="28" fill="#1e3a8a" rx="2"/>
            <rect x="196" y="155" width="8" height="28" fill="#1e3a8a" rx="2"/>
            <!-- Feet -->
            <ellipse cx="185" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <ellipse cx="200" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <!-- Body -->
            <rect x="178" y="115" width="32" height="40" fill="#2563eb" rx="4"/>
            <!-- Jersey stripes -->
            <rect x="178" y="125" width="32" height="4" fill="#1d4ed8" opacity="0.5"/>
            <rect x="178" y="135" width="32" height="4" fill="#1d4ed8" opacity="0.5"/>
            <!-- Number 1 -->
            <text x="194" y="140" text-anchor="middle" font-size="14" font-weight="900" fill="white">1</text>
            <!-- Arms pulling -->
            <line x1="210" y1="125" x2="235" y2="149" stroke="#fbbf24" stroke-width="10" stroke-linecap="round"/>
            <line x1="210" y1="132" x2="230" y2="149" stroke="#f59e0b" stroke-width="9" stroke-linecap="round"/>
            <!-- Head -->
            <circle cx="194" cy="102" r="15" fill="#fbbf24"/>
            <!-- Hair (helmet/cap) -->
            <path d="M 180,98 Q 194,84 208,98 L 208,104 L 180,104 Z" fill="#1e3a8a"/>
            <!-- Face: determined eyes, gritted teeth -->
            <circle cx="189" cy="104" r="2" fill="#1e293b"/>
            <circle cx="199" cy="104" r="2" fill="#1e293b"/>
            <line x1="186" y1="98" x2="192" y2="100" stroke="#1e293b" stroke-width="1.5"/>
            <line x1="196" y1="100" x2="202" y2="98" stroke="#1e293b" stroke-width="1.5"/>
            <rect x="188" y="109" width="12" height="2.5" fill="white" stroke="#92400e" stroke-width="0.5"/>
          </g>
          <!-- Character 2 (back) -->
          <g id="blue2">
            <ellipse cx="140" cy="185" rx="22" ry="4" fill="#000" opacity="0.15"/>
            <rect x="128" y="155" width="8" height="28" fill="#1e3a8a" rx="2"/>
            <rect x="141" y="155" width="8" height="28" fill="#1e3a8a" rx="2"/>
            <ellipse cx="130" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <ellipse cx="145" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <rect x="123" y="115" width="32" height="40" fill="#3b82f6" rx="4"/>
            <rect x="123" y="125" width="32" height="4" fill="#2563eb" opacity="0.5"/>
            <text x="139" y="140" text-anchor="middle" font-size="14" font-weight="900" fill="white">2</text>
            <!-- Arms overlapping with front character -->
            <line x1="155" y1="122" x2="178" y2="140" stroke="#fbbf24" stroke-width="9" stroke-linecap="round"/>
            <line x1="155" y1="130" x2="175" y2="145" stroke="#f59e0b" stroke-width="8" stroke-linecap="round"/>
            <circle cx="139" cy="102" r="14" fill="#fbbf24"/>
            <path d="M 126,98 Q 139,86 152,98 L 152,103 L 126,103 Z" fill="#60a5fa"/>
            <circle cx="134" cy="104" r="1.8" fill="#1e293b"/>
            <circle cx="144" cy="104" r="1.8" fill="#1e293b"/>
            <rect x="133" y="109" width="12" height="2.5" fill="white" stroke="#92400e" stroke-width="0.5"/>
          </g>
        </g>

        <!-- RED TEAM - 2 characters pulling rope to the right -->
        <g id="redTeam">
          <!-- Character 1 (front, mirror) -->
          <g id="red1">
            <ellipse cx="605" cy="185" rx="22" ry="4" fill="#000" opacity="0.15"/>
            <rect x="593" y="155" width="8" height="28" fill="#7f1d1d" rx="2"/>
            <rect x="606" y="155" width="8" height="28" fill="#7f1d1d" rx="2"/>
            <ellipse cx="595" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <ellipse cx="610" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <rect x="590" y="115" width="32" height="40" fill="#dc2626" rx="4"/>
            <rect x="590" y="125" width="32" height="4" fill="#b91c1c" opacity="0.5"/>
            <rect x="590" y="135" width="32" height="4" fill="#b91c1c" opacity="0.5"/>
            <text x="606" y="140" text-anchor="middle" font-size="14" font-weight="900" fill="white">1</text>
            <!-- Arms pulling to right -->
            <line x1="590" y1="125" x2="565" y2="149" stroke="#fcd34d" stroke-width="10" stroke-linecap="round"/>
            <line x1="590" y1="132" x2="570" y2="149" stroke="#fbbf24" stroke-width="9" stroke-linecap="round"/>
            <circle cx="606" cy="102" r="15" fill="#fcd34d"/>
            <path d="M 592,98 Q 606,84 620,98 L 620,104 L 592,104 Z" fill="#7f1d1d"/>
            <circle cx="601" cy="104" r="2" fill="#1e293b"/>
            <circle cx="611" cy="104" r="2" fill="#1e293b"/>
            <line x1="598" y1="98" x2="604" y2="100" stroke="#1e293b" stroke-width="1.5"/>
            <line x1="608" y1="100" x2="614" y2="98" stroke="#1e293b" stroke-width="1.5"/>
            <rect x="600" y="109" width="12" height="2.5" fill="white" stroke="#92400e" stroke-width="0.5"/>
          </g>
          <!-- Character 2 (back) -->
          <g id="red2">
            <ellipse cx="660" cy="185" rx="22" ry="4" fill="#000" opacity="0.15"/>
            <rect x="648" y="155" width="8" height="28" fill="#7f1d1d" rx="2"/>
            <rect x="661" y="155" width="8" height="28" fill="#7f1d1d" rx="2"/>
            <ellipse cx="650" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <ellipse cx="665" cy="185" rx="9" ry="3" fill="#1e293b"/>
            <rect x="645" y="115" width="32" height="40" fill="#ef4444" rx="4"/>
            <text x="661" y="140" text-anchor="middle" font-size="14" font-weight="900" fill="white">2</text>
            <line x1="645" y1="122" x2="622" y2="140" stroke="#fcd34d" stroke-width="9" stroke-linecap="round"/>
            <circle cx="661" cy="102" r="14" fill="#fcd34d"/>
            <path d="M 648,98 Q 661,86 674,98 L 674,103 L 648,103 Z" fill="#f87171"/>
            <circle cx="656" cy="104" r="1.8" fill="#1e293b"/>
            <circle cx="666" cy="104" r="1.8" fill="#1e293b"/>
            <rect x="655" y="109" width="12" height="2.5" fill="white" stroke="#92400e" stroke-width="0.5"/>
          </g>
        </g>

        <!-- Dust clouds near feet (show when pulling) -->
        <g id="dustL" opacity="0">
          <circle cx="160" cy="186" r="8" fill="#d4a574" opacity="0.6"/>
          <circle cx="145" cy="188" r="5" fill="#d4a574" opacity="0.4"/>
          <circle cx="175" cy="187" r="6" fill="#d4a574" opacity="0.5"/>
        </g>
        <g id="dustR" opacity="0">
          <circle cx="640" cy="186" r="8" fill="#d4a574" opacity="0.6"/>
          <circle cx="655" cy="188" r="5" fill="#d4a574" opacity="0.4"/>
          <circle cx="625" cy="187" r="6" fill="#d4a574" opacity="0.5"/>
        </g>

        <!-- All groups translate together with rope -->
      </svg>
    </div>

    <!-- Player panels -->
    <div class="grid md:grid-cols-2 gap-4">
      <!-- Player 1 (Blue) -->
      <div class="bg-white rounded-3xl shadow-xl p-5 border-t-8 border-blue-600">
        <h3 class="font-bold text-blue-600 mb-3 text-center text-lg" id="p1Label">🔵 Blue Team</h3>
        <div id="q1" class="text-center text-3xl md:text-4xl font-black text-slate-900 mb-3 min-h-[2.5rem]">—</div>
        <div id="d1" class="bg-slate-50 border-2 border-slate-200 rounded-xl py-3 text-center text-2xl font-bold mb-3 min-h-[3rem] transition-all">0</div>
        <div class="grid grid-cols-3 gap-1.5">
          {[1,2,3,4,5,6,7,8,9,'C',0,'OK'].map(k => (
            <button class="key1 py-3 rounded-lg font-bold text-lg active:scale-95 transition"
              class:list={[k === 'OK' ? 'bg-blue-600 text-white' : k === 'C' ? 'bg-orange-500 text-white' : 'bg-slate-100 hover:bg-slate-200']}
              data-key={String(k)}>
              {k === 'OK' ? 'PULL!' : k === 'C' ? '⌫' : k}
            </button>
          ))}
        </div>
      </div>

      <!-- Player 2 (Red) -->
      <div id="p2Panel" class="bg-white rounded-3xl shadow-xl p-5 border-t-8 border-red-600">
        <h3 class="font-bold text-red-600 mb-3 text-center text-lg" id="p2Label">🔴 Red Team</h3>
        <div id="q2" class="text-center text-3xl md:text-4xl font-black text-slate-900 mb-3 min-h-[2.5rem]">—</div>
        <div id="d2" class="bg-slate-50 border-2 border-slate-200 rounded-xl py-3 text-center text-2xl font-bold mb-3 min-h-[3rem] transition-all">0</div>
        <!-- Robot thinking display -->
        <div id="robotDisplay" class="hidden text-center py-6">
          <div class="text-5xl mb-2">🤖</div>
          <div class="text-slate-500 font-semibold" id="robotThinking">Thinking...</div>
        </div>
        <div id="p2Keys" class="grid grid-cols-3 gap-1.5">
          {[1,2,3,4,5,6,7,8,9,'C',0,'OK'].map(k => (
            <button class="key2 py-3 rounded-lg font-bold text-lg active:scale-95 transition"
              class:list={[k === 'OK' ? 'bg-red-600 text-white' : k === 'C' ? 'bg-orange-500 text-white' : 'bg-slate-100 hover:bg-slate-200']}
              data-key={String(k)}>
              {k === 'OK' ? 'PULL!' : k === 'C' ? '⌫' : k}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Win modal -->
  <div id="winModal" class="fixed inset-0 bg-black/70 z-50 hidden items-center justify-center p-4">
    <div id="confettiContainer" class="fixed inset-0 pointer-events-none overflow-hidden z-40"></div>
    <div class="bg-white rounded-3xl p-8 max-w-md w-full text-center relative z-50">
      <div class="text-8xl mb-3" id="winEmoji">🏆</div>
      <h2 id="winTitle" class="text-3xl font-black mb-2">Blue Team Wins!</h2>
      <p id="winSub" class="text-slate-600 mb-6">—</p>
      <div class="flex gap-3">
        <button id="rematchBtn" class="flex-1 py-3 rounded-2xl font-bold bg-gradient-to-r from-blue-600 to-red-600 text-white shadow-lg active:scale-95 transition">🔄 Rematch</button>
        <button id="changeBtn" class="flex-1 py-3 rounded-2xl font-bold bg-slate-200 text-slate-700 active:scale-95 transition">⚙️ Settings</button>
      </div>
    </div>
  </div>

  <section class="max-w-2xl mx-auto mt-16 prose prose-slate">
    <h2 class="text-2xl font-bold mb-4">How to Play</h2>
    <ol class="space-y-2 text-slate-700">
      <li>Choose your game mode: 2 Players or vs Robot.</li>
      <li>Each player solves their own math equation.</li>
      <li>Type the answer and press <strong>PULL!</strong></li>
      <li>Correct = your team pulls the rope toward your side!</li>
      <li>First team to reach the target number of pulls wins the championship.</li>
    </ol>
  </section>
</BaseLayout>

<style>
  .display-correct { animation: pulse-green 0.4s ease-out; }
  .display-wrong { animation: shake 0.4s ease-out; }
  @keyframes pulse-green {
    0%, 100% { transform: scale(1); background-color: rgb(248,250,252); }
    50% { transform: scale(1.05); background-color: rgb(187,247,208); border-color: rgb(34,197,94); }
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); background-color: rgb(248,250,252); }
    25% { transform: translateX(-6px); background-color: rgb(254,226,226); }
    75% { transform: translateX(6px); background-color: rgb(254,226,226); }
  }
  @keyframes pull-lean-left {
    0%, 100% { transform: rotate(0deg); }
    40% { transform: rotate(-18deg) translateX(-4px); }
    70% { transform: rotate(-8deg); }
  }
  @keyframes pull-lean-right {
    0%, 100% { transform: rotate(0deg); }
    40% { transform: rotate(18deg) translateX(4px); }
    70% { transform: rotate(8deg); }
  }
  .pull-blue #blueTeam { animation: pull-lean-left 0.6s ease-out; transform-origin: 170px 160px; }
  .pull-red #redTeam { animation: pull-lean-right 0.6s ease-out; transform-origin: 630px 160px; }
  .confetti-piece {
    position: absolute;
    pointer-events: none;
    animation: fall linear forwards;
  }
  @keyframes fall {
    0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }
</style>

<script>
  const setupScreen = document.getElementById('setupScreen');
  const gameScreen = document.getElementById('gameScreen');
  const winModal = document.getElementById('winModal');
  const confettiContainer = document.getElementById('confettiContainer');
  const startBtn = document.getElementById('startBtn');
  const rematchBtn = document.getElementById('rematchBtn');
  const changeBtn = document.getElementById('changeBtn');
  const gameCanvas = document.getElementById('gameCanvas') as SVGElement;
  const winTitle = document.getElementById('winTitle');
  const winSub = document.getElementById('winSub');
  const winEmoji = document.getElementById('winEmoji');
  const winScoreDisplay = document.getElementById('winScoreDisplay');
  const p1Name = document.getElementById('p1Name');
  const p2Name = document.getElementById('p2Name');
  const p1Label = document.getElementById('p1Label');
  const p2Label = document.getElementById('p2Label');
  const robotDisplay = document.getElementById('robotDisplay');
  const p2Keys = document.getElementById('p2Keys');
  const robotThinking = document.getElementById('robotThinking');
  const dustL = document.getElementById('dustL') as unknown as SVGGElement;
  const dustR = document.getElementById('dustR') as unknown as SVGGElement;

  let mode = '2p';
  let difficulty = 'easy';
  let winScore = 5;
  let p1Score = 0;
  let p2Score = 0;
  let ropeOffset = 0;
  let q1 = { text: '', answer: 0 };
  let q2 = { text: '', answer: 0 };
  let input1 = '';
  let input2 = '';
  let gameActive = false;
  let robotTimer: number | null = null;

  function beep(freq: number, dur = 0.08, type: OscillatorType = 'sine') {
    try {
      const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = type; osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.1, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
      osc.connect(gain); gain.connect(ctx.destination);
      osc.start(); osc.stop(ctx.currentTime + dur);
    } catch (e) {}
  }

  function rand(min: number, max: number) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  function genQ() {
    const ops = difficulty === 'easy' ? ['+', '−'] : difficulty === 'medium' ? ['+', '−', '×'] : ['+', '−', '×', '÷'];
    const op = ops[rand(0, ops.length - 1)];
    const max = difficulty === 'easy' ? 10 : 12;
    let a, b, ans, text;
    if (op === '+') { a = rand(1, max); b = rand(1, max); ans = a + b; text = `${a} + ${b} = ?`; }
    else if (op === '−') { a = rand(2, max); b = rand(1, a - 1); ans = a - b; text = `${a} − ${b} = ?`; }
    else if (op === '×') { a = rand(2, 9); b = rand(2, 9); ans = a * b; text = `${a} × ${b} = ?`; }
    else { ans = rand(2, 9); b = rand(2, 9); a = ans * b; text = `${a} ÷ ${b} = ?`; }
    return { text, answer: ans };
  }

  function moveRope(direction: 'left' | 'right') {
    const step = 30;
    ropeOffset += direction === 'left' ? -step : step;
    ropeOffset = Math.max(-winScore * step, Math.min(winScore * step, ropeOffset));

    // Translate everything: rope + characters
    const allGroups = gameCanvas.querySelectorAll('#rope, #rope2, #ropeMarker, #blueTeam, #redTeam');
    allGroups.forEach(el => {
      const current = el.getAttribute('transform') || '';
      const match = current.match(/translate\(([^,]+)/);
      const currentX = match ? parseFloat(match[1]) : 0;
      // Apply cumulative translation
    });
    // Simpler: translate the root groups
    const blueTeam = document.getElementById('blueTeam');
    const redTeam = document.getElementById('redTeam');
    const rope = document.getElementById('rope');
    const rope2 = document.getElementById('rope2');
    const ropeMarker = document.getElementById('ropeMarker');
    const dustLEl = dustL;
    const dustREl = dustR;

    [blueTeam, redTeam, rope, rope2, ropeMarker, dustLEl, dustREl].forEach(el => {
      if (el) el.setAttribute('transform', `translate(${ropeOffset}, 0)`);
    });
  }

  function flashDisplay(player: number, isCorrect: boolean) {
    const el = document.getElementById(`d${player}`);
    if (!el) return;
    el.classList.remove('display-correct', 'display-wrong');
    void el.offsetWidth;
    el.classList.add(isCorrect ? 'display-correct' : 'display-wrong');
  }

  function animatePull(player: number) {
    gameCanvas.classList.remove('pull-blue', 'pull-red');
    void gameCanvas.offsetWidth;
    gameCanvas.classList.add(player === 1 ? 'pull-blue' : 'pull-red');

    // Show dust
    const dust = player === 1 ? dustL : dustR;
    if (dust) {
      dust.style.opacity = '1';
      setTimeout(() => { dust.style.opacity = '0'; }, 500);
    }
    setTimeout(() => gameCanvas.classList.remove('pull-blue', 'pull-red'), 700);
  }

  function render() {
    document.getElementById('p1Score')!.textContent = String(p1Score);
    document.getElementById('p2Score')!.textContent = String(p2Score);
    document.getElementById('q1')!.textContent = q1.text;
    document.getElementById('d1')!.textContent = input1 || '0';
    if (mode === '2p') {
      document.getElementById('q2')!.textContent = q2.text;
      document.getElementById('d2')!.textContent = input2 || '0';
    }
  }

  function handleKey(player: number, key: string) {
    if (!gameActive) return;
    if (mode === 'cpu' && player === 2) return;
    beep(500, 0.04);
    let val = player === 1 ? input1 : input2;
    if (key === 'C') val = val.slice(0, -1);
    else if (key === 'OK') { submitAnswer(player); return; }
    else if (val.length < 4) val += key;
    if (player === 1) input1 = val; else input2 = val;
    render();
  }

  function submitAnswer(player: number) {
    const q = player === 1 ? q1 : q2;
    const val = parseInt(player === 1 ? input1 : input2);
    if (isNaN(val)) return;

    if (val === q.answer) {
      beep(880, 0.1);
      setTimeout(() => beep(1100, 0.1), 60);
      flashDisplay(player, true);
      animatePull(player);
      if (player === 1) {
        p1Score++;
        moveRope('left');
        input1 = '';
        q1 = genQ();
      } else {
        p2Score++;
        moveRope('right');
        if (mode === '2p') { input2 = ''; q2 = genQ(); }
        else { scheduleRobotAnswer(); }
      }
      render();
      if (p1Score >= winScore) showWin(1);
      else if (p2Score >= winScore) showWin(2);
    } else {
      beep(220, 0.15, 'sawtooth');
      flashDisplay(player, false);
      if (player === 1) input1 = ''; else input2 = '';
      setTimeout(render, 400);
    }
  }

  function scheduleRobotAnswer() {
    if (!gameActive) return;
    if (robotTimer) clearTimeout(robotTimer);

    const baseDelay = difficulty === 'easy' ? 3000 : difficulty === 'medium' ? 2000 : 1200;
    const delay = baseDelay + rand(0, 1000);
    const correct = difficulty === 'easy' ? 0.65 : difficulty === 'medium' ? 0.80 : 0.92;

    if (robotThinking) robotThinking.textContent = 'Thinking...';

    // Countdown animation
    let remaining = Math.floor(delay / 1000);
    const countdownTimer = setInterval(() => {
      remaining--;
      if (remaining > 0 && robotThinking) robotThinking.textContent = `Solving in ${remaining}s...`;
    }, 1000);

    robotTimer = window.setTimeout(() => {
      clearInterval(countdownTimer);
      if (!gameActive) return;
      if (robotThinking) robotThinking.textContent = '⚡ Answering!';
      const willBeCorrect = Math.random() < correct;
      const answer = willBeCorrect ? q2.answer : q2.answer + (Math.random() < 0.5 ? 1 : -1);
      input2 = String(answer);
      setTimeout(() => {
        submitAnswer(2);
        if (gameActive) {
          q2 = genQ();
          scheduleRobotAnswer();
        }
      }, 400);
    }, delay);
  }

  function spawnConfetti() {
    if (!confettiContainer) return;
    confettiContainer.innerHTML = '';
    const colors = ['#fbbf24', '#dc2626', '#2563eb', '#22c55e', '#a855f7', '#ec4899'];
    for (let i = 0; i < 80; i++) {
      const c = document.createElement('div');
      c.className = 'confetti-piece';
      c.style.cssText = `left: ${Math.random() * 100}%; top: -20px; width: 10px; height: 10px; background: ${colors[rand(0, colors.length - 1)]}; border-radius: ${Math.random() < 0.5 ? '50%' : '0'}; animation-duration: ${2 + Math.random() * 2}s; animation-delay: ${Math.random() * 0.5}s;`;
      confettiContainer.appendChild(c);
    }
    setTimeout(() => { if (confettiContainer) confettiContainer.innerHTML = ''; }, 4500);
  }

  function showWin(winner: number) {
    gameActive = false;
    if (robotTimer) clearTimeout(robotTimer);
    [523, 659, 784, 1046, 1318].forEach((f, i) => setTimeout(() => beep(f, 0.2), i * 120));
    const isBlue = winner === 1;
    const name = isBlue ? (mode === 'cpu' ? '🔵 You Win!' : '🔵 Blue Team Wins!') : (mode === 'cpu' ? '🤖 Robot Wins!' : '🔴 Red Team Wins!');
    if (winTitle) { winTitle.textContent = name; winTitle.className = `text-3xl font-black mb-2 ${isBlue ? 'text-blue-600' : 'text-red-600'}`; }
    if (winSub) winSub.textContent = `Score: ${p1Score} — ${p2Score}`;
    if (winEmoji) winEmoji.textContent = winner === 1 ? '🏆' : (mode === 'cpu' ? '🤖' : '🏆');
    setTimeout(() => {
      winModal?.classList.remove('hidden');
      winModal?.classList.add('flex');
      spawnConfetti();
    }, 700);
  }

  function startGame() {
    // Reset
    p1Score = 0; p2Score = 0; ropeOffset = 0;
    input1 = ''; input2 = '';
    q1 = genQ(); q2 = genQ();
    gameActive = true;
    if (robotTimer) clearTimeout(robotTimer);

    // Reset rope visuals
    ['rope', 'rope2', 'ropeMarker', 'blueTeam', 'redTeam', 'dustL', 'dustR'].forEach(id => {
      document.getElementById(id)?.removeAttribute('transform');
    });

    // Configure mode UI
    if (mode === 'cpu') {
      if (p1Label) p1Label.textContent = '🔵 You (Blue)';
      if (p2Label) p2Label.textContent = '🤖 Robot (Red)';
      if (p1Name) p1Name.textContent = 'You';
      if (p2Name) p2Name.textContent = 'Robot';
      robotDisplay?.classList.remove('hidden');
      p2Keys?.classList.add('hidden');
      document.getElementById('q2')!.textContent = q2.text;
      scheduleRobotAnswer();
    } else {
      if (p1Label) p1Label.textContent = '🔵 Blue Team';
      if (p2Label) p2Label.textContent = '🔴 Red Team';
      if (p1Name) p1Name.textContent = 'Blue';
      if (p2Name) p2Name.textContent = 'Red';
      robotDisplay?.classList.add('hidden');
      p2Keys?.classList.remove('hidden');
    }

    if (winScoreDisplay) winScoreDisplay.textContent = String(winScore);
    setupScreen?.classList.add('hidden');
    winModal?.classList.add('hidden');
    winModal?.classList.remove('flex');
    gameScreen?.classList.remove('hidden');
    if (confettiContainer) confettiContainer.innerHTML = '';
    render();
  }

  // Button handlers
  document.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.mode-btn').forEach(b => { b.removeAttribute('data-active'); b.classList.remove('border-blue-500', 'bg-blue-50'); b.classList.add('border-slate-200'); });
      btn.setAttribute('data-active', 'true'); btn.classList.remove('border-slate-200'); btn.classList.add('border-blue-500', 'bg-blue-50');
      mode = (btn as HTMLElement).dataset.mode || '2p';
    });
  });
  document.querySelectorAll('.diff-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.diff-btn').forEach(b => { b.removeAttribute('data-active'); b.classList.remove('border-blue-500', 'bg-blue-50'); b.classList.add('border-slate-200'); });
      btn.setAttribute('data-active', 'true'); btn.classList.remove('border-slate-200'); btn.classList.add('border-blue-500', 'bg-blue-50');
      difficulty = (btn as HTMLElement).dataset.diff || 'easy';
    });
  });
  document.querySelectorAll('.win-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.win-btn').forEach(b => { b.removeAttribute('data-active'); b.classList.remove('border-blue-500', 'bg-blue-50'); b.classList.add('border-slate-200'); });
      btn.setAttribute('data-active', 'true'); btn.classList.remove('border-slate-200'); btn.classList.add('border-blue-500', 'bg-blue-50');
      winScore = parseInt((btn as HTMLElement).dataset.win || '5');
    });
  });
  // Initialize active buttons
  ['mode-btn', 'diff-btn', 'win-btn'].forEach(cls => {
    document.querySelector(`.${cls}[data-active="true"]`)?.classList.add('border-blue-500', 'bg-blue-50');
  });

  document.querySelectorAll('.key1').forEach(btn => btn.addEventListener('click', () => handleKey(1, (btn as HTMLElement).dataset.key || '')));
  document.querySelectorAll('.key2').forEach(btn => btn.addEventListener('click', () => handleKey(2, (btn as HTMLElement).dataset.key || '')));

  startBtn?.addEventListener('click', startGame);
  rematchBtn?.addEventListener('click', startGame);
  changeBtn?.addEventListener('click', () => {
    if (robotTimer) clearTimeout(robotTimer);
    gameActive = false;
    setupScreen?.classList.remove('hidden');
    gameScreen?.classList.add('hidden');
    winModal?.classList.add('hidden');
    winModal?.classList.remove('flex');
    if (confettiContainer) confettiContainer.innerHTML = '';
  });
</script>
