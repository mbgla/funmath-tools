---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const content = {
  en: {
    title: 'Privacy Policy', updated: 'Last updated: April 2026',
    intro: 'At FunMath Tools, we take your privacy seriously. This Privacy Policy explains how we collect, use, and protect your information when you use our website.',
    s1_title: '1. Information We Collect',
    s1: 'FunMath Tools is designed to work without requiring personal information. We do not require sign-ups, accounts, or email addresses. We may collect: browser local storage data for game scores and preferences (stays on your device), anonymous usage statistics, and standard server logs.',
    s2_title: '2. Cookies',
    s2: 'We use cookies to remember your language preference, save game scores, and analyze website performance anonymously. You can disable cookies in your browser settings.',
    s3_title: '3. Third-Party Services',
    s3: 'We may use Google AdSense (ads), Google Analytics (anonymous stats), and Cloudflare (hosting). Each has its own privacy policy.',
    s4_title: '4. Children\'s Privacy',
    s4: 'FunMath Tools is safe for all ages. We do not knowingly collect personal information from children under 13.',
    s5_title: '5. Contact',
    s5: 'Questions about this Privacy Policy? Contact us at:',
  },
  ar: {
    title: 'سياسة الخصوصية', updated: 'آخر تحديث: أبريل 2026',
    intro: 'في فن-ماث تولز، نأخذ خصوصيتك بجدية. توضح سياسة الخصوصية هذه كيفية جمع واستخدام وحماية معلوماتك عند استخدام موقعنا.',
    s1_title: '١. المعلومات التي نجمعها',
    s1: 'تم تصميم فن-ماث تولز للعمل دون الحاجة إلى معلومات شخصية. لا نشترط التسجيل أو الحسابات أو عناوين البريد الإلكتروني. قد نجمع: بيانات التخزين المحلي للمتصفح لنتائج الألعاب والتفضيلات (تبقى على جهازك)، وإحصائيات استخدام مجهولة.',
    s2_title: '٢. ملفات تعريف الارتباط',
    s2: 'نستخدم ملفات تعريف الارتباط لتذكر تفضيل اللغة وحفظ نتائج الألعاب وتحليل أداء الموقع بشكل مجهول. يمكنك تعطيلها في إعدادات المتصفح.',
    s3_title: '٣. خدمات الطرف الثالث',
    s3: 'قد نستخدم Google AdSense للإعلانات، وGoogle Analytics للإحصائيات المجهولة، وCloudflare للاستضافة. لكل منها سياسة خصوصية خاصة بها.',
    s4_title: '٤. خصوصية الأطفال',
    s4: 'فن-ماث تولز آمن لجميع الأعمار. لا نجمع عن علم معلومات شخصية من الأطفال دون 13 عامًا.',
    s5_title: '٥. التواصل',
    s5: 'هل لديك أسئلة حول سياسة الخصوصية؟ تواصل معنا على:',
  },
  fr: {
    title: 'Politique de Confidentialité', updated: 'Dernière mise à jour: Avril 2026',
    intro: 'Chez FunMath Tools, nous prenons votre vie privée au sérieux. Cette politique explique comment nous collectons, utilisons et protégeons vos informations.',
    s1_title: '1. Informations Collectées',
    s1: 'FunMath Tools est conçu pour fonctionner sans informations personnelles. Nous ne demandons pas d\'inscription ou d\'email. Nous pouvons collecter des données de stockage local pour les scores (restent sur votre appareil) et des statistiques anonymes.',
    s2_title: '2. Cookies',
    s2: 'Nous utilisons des cookies pour retenir votre préférence de langue, sauvegarder les scores et analyser les performances du site de façon anonyme.',
    s3_title: '3. Services Tiers',
    s3: 'Nous utilisons Google AdSense (publicités), Google Analytics (statistiques anonymes) et Cloudflare (hébergement). Chacun a sa propre politique.',
    s4_title: '4. Confidentialité des Enfants',
    s4: 'FunMath Tools est sécurisé pour tous les âges. Nous ne collectons pas sciemment d\'informations personnelles d\'enfants de moins de 13 ans.',
    s5_title: '5. Contact',
    s5: 'Des questions sur cette politique? Contactez-nous:',
  },
};

const c = content[lang as keyof typeof content] || content.en;
---

<BaseLayout textContent={true} title={`${c.title} — FunMath Tools`} description={c.intro}>
  <div class="max-w-3xl mx-auto py-8">
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-brand-500">{t('nav.home' as any)}</a>
      <span class="mx-2">/</span>
      <span>{c.title}</span>
    </nav>

    <h1 class="text-4xl font-extrabold text-slate-900 mb-2">{c.title}</h1>
    <p class="text-slate-500 mb-8">{c.updated}</p>

    <div class="bg-white rounded-3xl shadow-lg p-8 space-y-6">
      <p class="text-slate-700">{c.intro}</p>
      <section><h2 class="text-xl font-bold mb-2 text-slate-900">{c.s1_title}</h2><p class="text-slate-700">{c.s1}</p></section>
      <section><h2 class="text-xl font-bold mb-2 text-slate-900">{c.s2_title}</h2><p class="text-slate-700">{c.s2}</p></section>
      <section><h2 class="text-xl font-bold mb-2 text-slate-900">{c.s3_title}</h2><p class="text-slate-700">{c.s3}</p></section>
      <section><h2 class="text-xl font-bold mb-2 text-slate-900">{c.s4_title}</h2><p class="text-slate-700">{c.s4}</p></section>
      <section>
        <h2 class="text-xl font-bold mb-2 text-slate-900">{c.s5_title}</h2>
        <p class="text-slate-700">{c.s5}</p>
        <p class="mt-2">📧 <a href="mailto:contact@funmath.tools" class="text-brand-500 hover:underline">contact@funmath.tools</a></p>
      </section>
    </div>
  </div>
</BaseLayout>
