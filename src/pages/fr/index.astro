---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl, getLocalizedPath } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const tools = [
  { id: 'random-number', emoji: '🎲', gradient: 'from-blue-400 to-indigo-600', available: true },
  { id: 'dice', emoji: '🎯', gradient: 'from-red-400 to-pink-600', available: true },
  { id: 'coin-flip', emoji: '🪙', gradient: 'from-yellow-400 to-orange-500', available: true },
  { id: 'spinner', emoji: '🎡', gradient: 'from-pink-400 to-purple-600', available: true },
  { id: 'times-tables', emoji: '✖️', gradient: 'from-green-400 to-emerald-600', available: true },
  { id: 'percentage', emoji: '%', gradient: 'from-teal-400 to-cyan-600', available: true },
  { id: 'stopwatch', emoji: '⏱️', gradient: 'from-purple-400 to-fuchsia-600', available: true },
];
---

<BaseLayout>
  <section class="text-center py-10">
    <div class="inline-block mb-4 px-4 py-1 bg-brand-100 text-brand-700 rounded-full text-sm font-medium">
      ✨ 100% Free · 7 Tools · No Signup
    </div>
    <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-4 leading-tight">
      {t('home.hero.title' as any)}
    </h1>
    <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto mb-8">
      {t('home.hero.subtitle' as any)}
    </p>
    <a 
      href="#tools" 
      class="inline-block bg-gradient-to-r from-brand-500 to-brand-600 text-white px-8 py-3 rounded-full font-bold shadow-lg shadow-brand-500/30 hover:shadow-xl hover:scale-105 transition"
    >
      {t('home.cta' as any)} →
    </a>
  </section>

  <section id="tools" class="mt-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {tools.map(tool => {
        const href = getLocalizedPath(`/tools/${tool.id}`, lang);
        return (
          <a 
            href={href}
            class="block rounded-2xl p-6 transition group relative overflow-hidden bg-white hover:-translate-y-1 hover:shadow-xl shadow-md cursor-pointer"
          >
            <div class:list={[
              'w-14 h-14 rounded-2xl flex items-center justify-center text-3xl mb-4 bg-gradient-to-br text-white font-black',
              tool.gradient
            ]}>
              {tool.emoji}
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-1">
              {t(`tool.${tool.id}.name` as any)}
            </h3>
            <p class="text-sm text-slate-600">
              {t(`tool.${tool.id}.desc` as any)}
            </p>
            <div class="mt-4 text-brand-500 font-semibold text-sm group-hover:translate-x-1 transition">
              Try it →
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <section class="mt-20 max-w-3xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-4">
      Why FunMath Tools?
    </h2>
    <div class="grid md:grid-cols-3 gap-6 mt-8 text-start">
      <div class="p-4">
        <div class="text-3xl mb-2">🎓</div>
        <h3 class="font-bold mb-1">For Teachers</h3>
        <p class="text-sm text-slate-600">Classroom-ready tools that keep students engaged.</p>
      </div>
      <div class="p-4">
        <div class="text-3xl mb-2">🏠</div>
        <h3 class="font-bold mb-1">For Parents</h3>
        <p class="text-sm text-slate-600">Support homeschooling with fun, interactive math.</p>
      </div>
      <div class="p-4">
        <div class="text-3xl mb-2">📱</div>
        <h3 class="font-bold mb-1">Any Device</h3>
        <p class="text-sm text-slate-600">Works on phones, tablets, and classroom screens.</p>
      </div>
    </div>
  </section>
</BaseLayout>
