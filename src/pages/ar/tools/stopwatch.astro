---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const title = `${t('tool.stopwatch.name' as any)} — FunMath Tools`;
const description = t('tool.stopwatch.long' as any);
---

<BaseLayout title={title} description={description}>
  <nav class="text-sm text-slate-500 mb-4">
    <a href="/" class="hover:text-brand-500">{t('nav.home' as any)}</a>
    <span class="mx-2">/</span>
    <span>{t('tool.stopwatch.name' as any)}</span>
  </nav>

  <div class="text-center mb-8">
    <div class="inline-flex w-20 h-20 rounded-3xl bg-gradient-to-br from-purple-400 to-fuchsia-600 items-center justify-center text-5xl mb-4">⏱️</div>
    <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-3">{t('tool.stopwatch.name' as any)}</h1>
    <p class="text-slate-600 max-w-xl mx-auto">{t('tool.stopwatch.long' as any)}</p>
  </div>

  <div class="max-w-2xl mx-auto bg-white rounded-3xl shadow-xl p-6 md:p-8">
    
    <!-- Mode tabs -->
    <div class="flex gap-2 bg-slate-100 p-1 rounded-2xl mb-6">
      <button id="modeSw" class="mode-btn flex-1 py-2 rounded-xl font-bold transition bg-white shadow text-brand-600">
        ⏱️ {t('stopwatch.sw' as any)}
      </button>
      <button id="modeTimer" class="mode-btn flex-1 py-2 rounded-xl font-bold transition text-slate-500">
        ⏲️ {t('stopwatch.timer' as any)}
      </button>
    </div>

    <!-- Timer Setup (hidden when stopwatch mode) -->
    <div id="timerSetup" class="hidden grid grid-cols-3 gap-2 mb-6">
      <div>
        <label class="block text-xs font-semibold text-slate-600 mb-1 text-center">H</label>
        <input type="number" id="inputH" value="0" min="0" max="23" class="w-full px-3 py-2 border-2 border-slate-200 rounded-xl text-center text-lg font-bold focus:border-brand-500 focus:outline-none"/>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-600 mb-1 text-center">M</label>
        <input type="number" id="inputM" value="5" min="0" max="59" class="w-full px-3 py-2 border-2 border-slate-200 rounded-xl text-center text-lg font-bold focus:border-brand-500 focus:outline-none"/>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-600 mb-1 text-center">S</label>
        <input type="number" id="inputS" value="0" min="0" max="59" class="w-full px-3 py-2 border-2 border-slate-200 rounded-xl text-center text-lg font-bold focus:border-brand-500 focus:outline-none"/>
      </div>
    </div>

    <!-- Display -->
    <div id="display" class="text-center py-8">
      <div class="text-6xl md:text-8xl font-black font-mono tabular-nums bg-gradient-to-br from-purple-600 to-fuchsia-600 bg-clip-text text-transparent">
        <span id="time">00:00:00</span>
      </div>
      <div id="ms" class="text-2xl font-mono text-slate-400 mt-2">.000</div>
    </div>

    <!-- Controls -->
    <div class="grid grid-cols-2 gap-3">
      <button id="startBtn" class="py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-green-500 to-emerald-600 text-white shadow-lg shadow-green-500/30 hover:shadow-xl active:scale-95 transition">
        ▶ {t('stopwatch.start' as any)}
      </button>
      <button id="resetBtn" class="py-4 rounded-2xl font-bold text-lg bg-slate-200 text-slate-700 hover:bg-slate-300 active:scale-95 transition">
        🔄 {t('stopwatch.reset' as any)}
      </button>
    </div>
    <button id="lapBtn" class="hidden mt-3 w-full py-3 rounded-2xl font-bold bg-blue-100 text-blue-700 hover:bg-blue-200 active:scale-95 transition">
      🏁 {t('stopwatch.lap' as any)}
    </button>

    <!-- Laps -->
    <div id="lapsSection" class="hidden mt-6">
      <h3 class="font-bold text-slate-700 mb-2">{t('stopwatch.lap' as any)}s</h3>
      <div id="laps" class="space-y-1 max-h-40 overflow-y-auto"></div>
    </div>

    <!-- Timer done message -->
    <div id="doneMsg" class="hidden mt-6 p-4 bg-red-100 border-2 border-red-400 rounded-2xl text-center">
      <div class="text-3xl mb-2">⏰</div>
      <div class="font-bold text-red-700 text-lg">{t('stopwatch.done' as any)}</div>
    </div>
  </div>
</BaseLayout>

<script>
  let mode: 'stopwatch' | 'timer' = 'stopwatch';
  let running = false;
  let startTime = 0;
  let elapsed = 0;  // milliseconds
  let timerTarget = 0; // for timer mode
  let rafId: number | null = null;
  let laps: number[] = [];

  const timeEl = document.getElementById('time');
  const msEl = document.getElementById('ms');
  const startBtn = document.getElementById('startBtn');
  const resetBtn = document.getElementById('resetBtn');
  const lapBtn = document.getElementById('lapBtn');
  const lapsSection = document.getElementById('lapsSection');
  const lapsDiv = document.getElementById('laps');
  const doneMsg = document.getElementById('doneMsg');
  const timerSetup = document.getElementById('timerSetup');
  const inputH = document.getElementById('inputH') as HTMLInputElement;
  const inputM = document.getElementById('inputM') as HTMLInputElement;
  const inputS = document.getElementById('inputS') as HTMLInputElement;
  const modeSwBtn = document.getElementById('modeSw');
  const modeTimerBtn = document.getElementById('modeTimer');

  function format(ms: number): { main: string; ms: string } {
    const abs = Math.max(0, Math.floor(ms));
    const h = Math.floor(abs / 3600000);
    const m = Math.floor((abs % 3600000) / 60000);
    const s = Math.floor((abs % 60000) / 1000);
    const milli = abs % 1000;
    const pad = (n: number, d=2) => String(n).padStart(d, '0');
    return { main: `${pad(h)}:${pad(m)}:${pad(s)}`, ms: `.${pad(milli, 3)}` };
  }

  function render(ms: number) {
    const f = format(ms);
    if (timeEl) timeEl.textContent = f.main;
    if (msEl) msEl.textContent = f.ms;
  }

  function tick() {
    if (!running) return;
    const now = Date.now();
    if (mode === 'stopwatch') {
      const current = elapsed + (now - startTime);
      render(current);
    } else {
      const remaining = timerTarget - now;
      if (remaining <= 0) {
        render(0);
        finishTimer();
        return;
      }
      render(remaining);
    }
    rafId = requestAnimationFrame(tick);
  }

  function finishTimer() {
    running = false;
    if (rafId) cancelAnimationFrame(rafId);
    doneMsg?.classList.remove('hidden');
    playAlarm();
    updateButtons();
  }

  function playAlarm() {
    try {
      const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      [0, 0.3, 0.6].forEach(delay => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.frequency.value = 880;
        osc.type = 'sine';
        gain.gain.setValueAtTime(0.3, ctx.currentTime + delay);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + delay + 0.25);
        osc.connect(gain); gain.connect(ctx.destination);
        osc.start(ctx.currentTime + delay);
        osc.stop(ctx.currentTime + delay + 0.25);
      });
    } catch(e) {}
  }

  function updateButtons() {
    if (!startBtn) return;
    const isStopwatch = mode === 'stopwatch';
    if (running) {
      startBtn.innerHTML = '⏸ Pause';
      startBtn.className = 'py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-amber-500 to-orange-500 text-white shadow-lg active:scale-95 transition';
      if (isStopwatch) lapBtn?.classList.remove('hidden');
    } else {
      startBtn.innerHTML = '▶ Start';
      startBtn.className = 'py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-green-500 to-emerald-600 text-white shadow-lg active:scale-95 transition';
      lapBtn?.classList.add('hidden');
    }
  }

  function toggleStart() {
    doneMsg?.classList.add('hidden');
    if (running) {
      running = false;
      if (mode === 'stopwatch') elapsed += Date.now() - startTime;
      if (rafId) cancelAnimationFrame(rafId);
    } else {
      if (mode === 'timer' && timerTarget === 0) {
        const total = (parseInt(inputH.value) || 0) * 3600000 
                    + (parseInt(inputM.value) || 0) * 60000 
                    + (parseInt(inputS.value) || 0) * 1000;
        if (total <= 0) return;
        timerTarget = Date.now() + total;
      } else if (mode === 'timer') {
        // resuming: recalculate target based on displayed time
        const displayed = (timeEl?.textContent || '00:00:00').split(':').map(n => parseInt(n));
        const ms = displayed[0]*3600000 + displayed[1]*60000 + displayed[2]*1000;
        timerTarget = Date.now() + ms;
      }
      startTime = Date.now();
      running = true;
      tick();
    }
    updateButtons();
  }

  function reset() {
    running = false;
    if (rafId) cancelAnimationFrame(rafId);
    elapsed = 0;
    timerTarget = 0;
    laps = [];
    render(0);
    doneMsg?.classList.add('hidden');
    lapsSection?.classList.add('hidden');
    if (lapsDiv) lapsDiv.innerHTML = '';
    updateButtons();
  }

  function addLap() {
    if (mode !== 'stopwatch' || !running) return;
    const current = elapsed + (Date.now() - startTime);
    laps.unshift(current);
    renderLaps();
  }

  function renderLaps() {
    if (!lapsDiv || !lapsSection) return;
    lapsSection.classList.toggle('hidden', laps.length === 0);
    lapsDiv.innerHTML = laps.map((lap, i) => {
      const f = format(lap);
      const lapNum = laps.length - i;
      return `<div class="flex justify-between px-3 py-2 bg-slate-50 rounded-lg font-mono text-sm">
        <span class="text-slate-500">Lap ${lapNum}</span>
        <span class="font-bold">${f.main}${f.ms}</span>
      </div>`;
    }).join('');
  }

  function setMode(newMode: 'stopwatch' | 'timer') {
    mode = newMode;
    reset();
    const isSw = mode === 'stopwatch';
    modeSwBtn?.classList.toggle('bg-white', isSw);
    modeSwBtn?.classList.toggle('shadow', isSw);
    modeSwBtn?.classList.toggle('text-brand-600', isSw);
    modeSwBtn?.classList.toggle('text-slate-500', !isSw);
    modeTimerBtn?.classList.toggle('bg-white', !isSw);
    modeTimerBtn?.classList.toggle('shadow', !isSw);
    modeTimerBtn?.classList.toggle('text-brand-600', !isSw);
    modeTimerBtn?.classList.toggle('text-slate-500', isSw);
    timerSetup?.classList.toggle('hidden', isSw);
  }

  startBtn?.addEventListener('click', toggleStart);
  resetBtn?.addEventListener('click', reset);
  lapBtn?.addEventListener('click', addLap);
  modeSwBtn?.addEventListener('click', () => setMode('stopwatch'));
  modeTimerBtn?.addEventListener('click', () => setMode('timer'));

  render(0);
</script>
