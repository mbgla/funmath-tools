---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const title = 'Math Bingo — Classroom Math Game | FunMath Tools';
const description = 'Free online math bingo game. Solve the equation and find the answer on your bingo card. Perfect for classrooms and family game night.';
---

<BaseLayout title={title} description={description}>
  <nav class="text-sm text-slate-500 mb-4">
    <a href="/" class="hover:text-brand-500">Home</a>
    <span class="mx-2">/</span>
    <a href="/#games" class="hover:text-brand-500">Games</a>
    <span class="mx-2">/</span>
    <span>Math Bingo</span>
  </nav>

  <div class="text-center mb-6">
    <div class="inline-flex w-20 h-20 rounded-3xl bg-gradient-to-br from-green-500 to-teal-500 items-center justify-center text-5xl mb-4">🎰</div>
    <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-3">Math Bingo</h1>
    <p class="text-slate-600 max-w-xl mx-auto">Solve equations and mark the answers on your card. Get 5 in a row to win!</p>
  </div>

  <!-- Setup screen -->
  <div id="setupScreen" class="max-w-2xl mx-auto bg-white rounded-3xl shadow-xl p-6 md:p-8">
    <h2 class="font-bold text-lg text-slate-800 mb-4 text-center">Choose Operations</h2>
    <div class="grid grid-cols-4 gap-2 mb-6">
      <label class="cursor-pointer">
        <input type="checkbox" class="op-cb peer sr-only" value="+" checked />
        <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-green-500 peer-checked:text-white peer-checked:border-green-500 transition">+</div>
      </label>
      <label class="cursor-pointer">
        <input type="checkbox" class="op-cb peer sr-only" value="-" checked />
        <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-green-500 peer-checked:text-white peer-checked:border-green-500 transition">−</div>
      </label>
      <label class="cursor-pointer">
        <input type="checkbox" class="op-cb peer sr-only" value="*" checked />
        <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-green-500 peer-checked:text-white peer-checked:border-green-500 transition">×</div>
      </label>
      <label class="cursor-pointer">
        <input type="checkbox" class="op-cb peer sr-only" value="/" />
        <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-green-500 peer-checked:text-white peer-checked:border-green-500 transition">÷</div>
      </label>
    </div>

    <h2 class="font-bold text-lg text-slate-800 mb-4 text-center">Win Condition</h2>
    <div class="grid grid-cols-3 gap-3 mb-6">
      <button class="win-btn py-3 rounded-xl font-bold border-2 border-slate-200 hover:border-green-500 transition" data-win="line" data-active="true">
        <div class="text-xl mb-1">📏</div>
        <div>Line</div>
        <div class="text-xs text-slate-500 font-normal">Row, col, or diagonal</div>
      </button>
      <button class="win-btn py-3 rounded-xl font-bold border-2 border-slate-200 hover:border-green-500 transition" data-win="corners">
        <div class="text-xl mb-1">🎯</div>
        <div>Corners</div>
        <div class="text-xs text-slate-500 font-normal">All 4 corners</div>
      </button>
      <button class="win-btn py-3 rounded-xl font-bold border-2 border-slate-200 hover:border-green-500 transition" data-win="full">
        <div class="text-xl mb-1">💯</div>
        <div>Blackout</div>
        <div class="text-xs text-slate-500 font-normal">All 25 cells</div>
      </button>
    </div>

    <button id="startBtn" class="w-full py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-green-500 to-teal-500 text-white shadow-lg active:scale-95 transition">
      🎰 Start Bingo
    </button>
  </div>

  <!-- Game screen -->
  <div id="gameScreen" class="hidden max-w-2xl mx-auto">
    <!-- Current question -->
    <div class="bg-white rounded-3xl shadow-xl p-5 mb-4 text-center">
      <div class="text-xs text-slate-500 font-bold mb-1">SOLVE THIS</div>
      <div id="question" class="text-4xl md:text-5xl font-black text-slate-900 mb-3">—</div>
      <div class="text-sm text-slate-500">Find the answer on your card!</div>
      <button id="newCallBtn" class="mt-3 px-5 py-2 rounded-xl font-bold bg-gradient-to-r from-green-500 to-teal-500 text-white shadow active:scale-95 text-sm">
        🎲 New Call
      </button>
    </div>

    <!-- Bingo card -->
    <div class="bg-white rounded-3xl shadow-xl p-5">
      <div class="grid grid-cols-5 gap-1.5 md:gap-2 mb-3">
        <!-- Headers -->
        <div class="text-center font-black text-green-600 text-lg">B</div>
        <div class="text-center font-black text-green-600 text-lg">I</div>
        <div class="text-center font-black text-green-600 text-lg">N</div>
        <div class="text-center font-black text-green-600 text-lg">G</div>
        <div class="text-center font-black text-green-600 text-lg">O</div>
      </div>
      <div id="bingoCard" class="grid grid-cols-5 gap-1.5 md:gap-2"></div>
      <div class="mt-4 flex justify-between text-sm font-semibold">
        <span class="text-slate-500">Marked: <span id="markedCount">1</span>/25</span>
        <button id="restartBtn" class="text-red-500 hover:text-red-700">🔄 Restart</button>
      </div>
    </div>
  </div>

  <!-- Win screen -->
  <div id="winScreen" class="hidden max-w-md mx-auto mt-8 bg-white rounded-3xl shadow-xl p-8 text-center">
    <div class="text-7xl mb-3">🏆</div>
    <h2 class="text-3xl font-black mb-2 bg-gradient-to-r from-green-500 to-teal-500 bg-clip-text text-transparent">BINGO!</h2>
    <p class="text-slate-600 mb-6" id="winStats">You won in 0 calls</p>
    <div class="flex gap-3">
      <button id="playAgainBtn" class="flex-1 py-3 rounded-2xl font-bold bg-gradient-to-r from-green-500 to-teal-500 text-white shadow-lg active:scale-95 transition">
        🔄 New Card
      </button>
      <button id="changeBtn" class="flex-1 py-3 rounded-2xl font-bold bg-slate-200 text-slate-700 active:scale-95 transition">
        ⚙️ Settings
      </button>
    </div>
  </div>

  <section class="max-w-2xl mx-auto mt-16 prose prose-slate">
    <h2 class="text-2xl font-bold mb-4">How to Play</h2>
    <ol class="space-y-2 text-slate-700">
      <li>Each turn, an equation is called.</li>
      <li>Solve the equation in your head.</li>
      <li>Find that answer on your bingo card and click it!</li>
      <li>Get 5 in a row (line, column, or diagonal) to win.</li>
    </ol>
    <p class="text-slate-700 mt-4">The center FREE square is automatically marked.</p>
  </section>
</BaseLayout>

<script>
  const setupScreen = document.getElementById('setupScreen');
  const gameScreen = document.getElementById('gameScreen');
  const winScreen = document.getElementById('winScreen');
  const startBtn = document.getElementById('startBtn');
  const playAgainBtn = document.getElementById('playAgainBtn');
  const changeBtn = document.getElementById('changeBtn');
  const restartBtn = document.getElementById('restartBtn');
  const newCallBtn = document.getElementById('newCallBtn');
  const bingoCard = document.getElementById('bingoCard');
  const questionEl = document.getElementById('question');
  const markedCountEl = document.getElementById('markedCount');
  const winStats = document.getElementById('winStats');

  let card: number[] = [];
  let marked: boolean[] = [];
  let currentAnswer = 0;
  let winCondition = 'line';
  let callCount = 0;
  let won = false;

  function beep(freq: number, dur = 0.06, type: OscillatorType = 'sine') {
    try {
      const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = type;
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.1, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
      osc.connect(gain); gain.connect(ctx.destination);
      osc.start(); osc.stop(ctx.currentTime + dur);
    } catch (e) {}
  }

  function rand(min: number, max: number): number {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  function getOps(): string[] {
    const cbs = document.querySelectorAll('.op-cb:checked') as NodeListOf<HTMLInputElement>;
    const ops = Array.from(cbs).map(cb => cb.value);
    return ops.length > 0 ? ops : ['+'];
  }

  function genEquation(): { text: string; answer: number } {
    const ops = getOps();
    const op = ops[rand(0, ops.length - 1)];
    let a, b, ans, text;
    if (op === '+') { a = rand(1, 25); b = rand(1, 25); ans = a + b; text = `${a} + ${b}`; }
    else if (op === '-') { a = rand(5, 50); b = rand(1, a - 1); ans = a - b; text = `${a} − ${b}`; }
    else if (op === '*') { a = rand(2, 9); b = rand(2, 9); ans = a * b; text = `${a} × ${b}`; }
    else { ans = rand(2, 12); b = rand(2, 9); a = ans * b; text = `${a} ÷ ${b}`; }
    return { text, answer: ans };
  }

  function generateCard() {
    // Generate 24 unique answers + 1 FREE space in middle
    const answers = new Set<number>();
    const equations: { text: string; answer: number }[] = [];

    while (answers.size < 24) {
      const eq = genEquation();
      if (!answers.has(eq.answer)) {
        answers.add(eq.answer);
        equations.push(eq);
      }
    }

    card = Array.from(answers);
    // Shuffle
    for (let i = card.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [card[i], card[j]] = [card[j], card[i]];
    }
    // Insert FREE at center (index 12)
    card.splice(12, 0, 0); // 0 = FREE

    marked = card.map((_, i) => i === 12); // center marked
    callCount = 0;
    won = false;
  }

  function renderCard() {
    if (!bingoCard) return;
    bingoCard.innerHTML = '';
    card.forEach((value, i) => {
      const div = document.createElement('button');
      const isFree = i === 12;
      const isMarked = marked[i];

      let classes = 'aspect-square rounded-lg flex items-center justify-center font-black text-base md:text-xl border-2 transition active:scale-95 ';
      if (isFree) {
        classes += 'bg-gradient-to-br from-green-400 to-teal-500 text-white border-transparent';
      } else if (isMarked) {
        classes += 'bg-gradient-to-br from-emerald-400 to-green-500 text-white border-transparent';
      } else {
        classes += 'bg-white border-slate-300 text-slate-700 hover:border-green-500';
      }

      div.className = classes;
      div.textContent = isFree ? '★' : String(value);
      if (!isFree) {
        div.addEventListener('click', () => markCell(i));
      }
      bingoCard?.appendChild(div);
    });

    if (markedCountEl) {
      markedCountEl.textContent = String(marked.filter(m => m).length);
    }
  }

  function callNewEquation() {
    if (won) return;
    callCount++;
    // Get a value from card that's not yet marked
    const unmarkedIndices = card
      .map((_, i) => i)
      .filter(i => !marked[i] && i !== 12);

    if (unmarkedIndices.length === 0) return;

    // 80% chance: pick something on the card
    // 20% chance: random other value (to keep it challenging)
    let answer: number;
    if (Math.random() < 0.8 && unmarkedIndices.length > 0) {
      const idx = unmarkedIndices[rand(0, unmarkedIndices.length - 1)];
      answer = card[idx];
    } else {
      answer = rand(1, 100);
    }

    // Generate equation that has this answer
    const ops = getOps();
    const op = ops[rand(0, ops.length - 1)];
    let text = '';

    if (op === '+' && answer >= 2) {
      const a = rand(1, answer - 1);
      text = `${a} + ${answer - a}`;
    } else if (op === '-') {
      const a = answer + rand(1, 20);
      text = `${a} − ${a - answer}`;
    } else if (op === '*' && answer >= 2) {
      // Find factors
      const factors: number[] = [];
      for (let f = 2; f <= Math.min(12, answer); f++) {
        if (answer % f === 0) factors.push(f);
      }
      if (factors.length > 0) {
        const f = factors[rand(0, factors.length - 1)];
        text = `${f} × ${answer / f}`;
      } else {
        text = `${answer} + 0`;
      }
    } else if (op === '/') {
      const b = rand(2, 9);
      text = `${answer * b} ÷ ${b}`;
    } else {
      text = `${answer} + 0`;
    }

    if (questionEl) questionEl.textContent = text;
    currentAnswer = answer;
    beep(660, 0.1);
  }

  function markCell(index: number) {
    if (won || index === 12) return;
    if (card[index] === currentAnswer && !marked[index]) {
      marked[index] = true;
      beep(880, 0.1);
      setTimeout(() => beep(1100, 0.1), 80);
      renderCard();
      checkWin();
    } else if (marked[index]) {
      // Already marked
      beep(440, 0.05);
    } else {
      // Wrong cell
      beep(220, 0.15, 'sawtooth');
    }
  }

  function checkWin() {
    let isWin = false;

    if (winCondition === 'line') {
      // Rows
      for (let r = 0; r < 5; r++) {
        if (marked.slice(r * 5, r * 5 + 5).every(m => m)) { isWin = true; break; }
      }
      // Columns
      if (!isWin) {
        for (let c = 0; c < 5; c++) {
          if ([0,1,2,3,4].every(r => marked[r * 5 + c])) { isWin = true; break; }
        }
      }
      // Diagonals
      if (!isWin && [0, 6, 12, 18, 24].every(i => marked[i])) isWin = true;
      if (!isWin && [4, 8, 12, 16, 20].every(i => marked[i])) isWin = true;
    } else if (winCondition === 'corners') {
      isWin = marked[0] && marked[4] && marked[20] && marked[24];
    } else if (winCondition === 'full') {
      isWin = marked.every(m => m);
    }

    if (isWin) {
      won = true;
      [523, 659, 784, 1046, 1318].forEach((f, i) => setTimeout(() => beep(f, 0.2), i * 100));
      if (winStats) winStats.textContent = `You won in ${callCount} calls! 🎉`;
      setTimeout(() => {
        gameScreen?.classList.add('hidden');
        winScreen?.classList.remove('hidden');
      }, 600);
    }
  }

  function startGame() {
    setupScreen?.classList.add('hidden');
    winScreen?.classList.add('hidden');
    gameScreen?.classList.remove('hidden');
    generateCard();
    renderCard();
    callNewEquation();
  }

  function showSetup() {
    setupScreen?.classList.remove('hidden');
    gameScreen?.classList.add('hidden');
    winScreen?.classList.add('hidden');
  }

  document.querySelectorAll('.win-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.win-btn').forEach(b => {
        b.removeAttribute('data-active');
        b.classList.remove('border-green-500', 'bg-green-50');
      });
      btn.setAttribute('data-active', 'true');
      btn.classList.add('border-green-500', 'bg-green-50');
      winCondition = (btn as HTMLElement).dataset.win || 'line';
    });
  });
  document.querySelector('.win-btn[data-active="true"]')?.classList.add('border-green-500', 'bg-green-50');

  startBtn?.addEventListener('click', startGame);
  playAgainBtn?.addEventListener('click', startGame);
  restartBtn?.addEventListener('click', startGame);
  changeBtn?.addEventListener('click', showSetup);
  newCallBtn?.addEventListener('click', callNewEquation);
</script>
