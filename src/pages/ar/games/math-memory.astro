---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const title = 'Math Memory Match — Match Equations Game | FunMath Tools';
const description = 'Free online memory game where you match math equations with their answers. Perfect for kids learning addition, subtraction, multiplication, and division.';
---

<BaseLayout title={title} description={description}>
  <nav class="text-sm text-slate-500 mb-4">
    <a href="/" class="hover:text-brand-500">Home</a>
    <span class="mx-2">/</span>
    <a href="/#games" class="hover:text-brand-500">Games</a>
    <span class="mx-2">/</span>
    <span>Math Memory Match</span>
  </nav>

  <div class="text-center mb-8">
    <div class="inline-flex w-20 h-20 rounded-3xl bg-gradient-to-br from-violet-400 to-purple-600 items-center justify-center text-5xl mb-4">🧠</div>
    <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-3">Math Memory Match</h1>
    <p class="text-slate-600 max-w-xl mx-auto">Match equations with their answers. Train your memory and math at the same time!</p>
  </div>

  <div class="max-w-2xl mx-auto bg-white rounded-3xl shadow-xl p-6 md:p-8">

    <!-- Setup screen -->
    <div id="setupScreen">
      <h2 class="font-bold text-lg text-slate-800 mb-4 text-center">Choose Difficulty</h2>
      <div class="grid grid-cols-3 gap-3 mb-6">
        <button class="diff-btn p-4 rounded-2xl font-bold border-2 border-slate-200 hover:border-violet-500 transition" data-pairs="6" data-active="true">
          <div class="text-2xl mb-1">🌱</div>
          <div>Easy</div>
          <div class="text-xs text-slate-500 font-normal">12 cards</div>
        </button>
        <button class="diff-btn p-4 rounded-2xl font-bold border-2 border-slate-200 hover:border-violet-500 transition" data-pairs="8">
          <div class="text-2xl mb-1">🔥</div>
          <div>Medium</div>
          <div class="text-xs text-slate-500 font-normal">16 cards</div>
        </button>
        <button class="diff-btn p-4 rounded-2xl font-bold border-2 border-slate-200 hover:border-violet-500 transition" data-pairs="10">
          <div class="text-2xl mb-1">⚡</div>
          <div>Hard</div>
          <div class="text-xs text-slate-500 font-normal">20 cards</div>
        </button>
      </div>

      <h2 class="font-bold text-lg text-slate-800 mb-4 text-center">Operations</h2>
      <div class="grid grid-cols-4 gap-2 mb-6">
        <label class="cursor-pointer">
          <input type="checkbox" class="op-cb peer sr-only" value="+" checked />
          <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-violet-500 peer-checked:text-white peer-checked:border-violet-500 transition">+</div>
        </label>
        <label class="cursor-pointer">
          <input type="checkbox" class="op-cb peer sr-only" value="-" checked />
          <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-violet-500 peer-checked:text-white peer-checked:border-violet-500 transition">−</div>
        </label>
        <label class="cursor-pointer">
          <input type="checkbox" class="op-cb peer sr-only" value="*" />
          <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-violet-500 peer-checked:text-white peer-checked:border-violet-500 transition">×</div>
        </label>
        <label class="cursor-pointer">
          <input type="checkbox" class="op-cb peer sr-only" value="/" />
          <div class="py-3 text-center font-bold rounded-xl border-2 border-slate-200 text-slate-500 peer-checked:bg-violet-500 peer-checked:text-white peer-checked:border-violet-500 transition">÷</div>
        </label>
      </div>

      <button id="startBtn" class="w-full py-4 rounded-2xl font-bold text-lg bg-gradient-to-r from-violet-500 to-purple-600 text-white shadow-lg shadow-violet-500/30 active:scale-95 transition">
        🧠 Start Game
      </button>
    </div>

    <!-- Game screen -->
    <div id="gameScreen" class="hidden">
      <div class="flex justify-between items-center mb-4 font-semibold text-sm">
        <div class="bg-violet-100 text-violet-700 px-3 py-1 rounded-full">
          Moves: <span id="moves">0</span>
        </div>
        <div class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full">
          ⏱ <span id="timer">0:00</span>
        </div>
        <div class="bg-green-100 text-green-700 px-3 py-1 rounded-full">
          ✓ <span id="matched">0</span>/<span id="totalPairs">6</span>
        </div>
      </div>

      <div id="board" class="grid gap-2 mb-4"></div>

      <button id="restartBtn" class="w-full py-2 rounded-xl font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 transition text-sm">
        🔄 Restart
      </button>
    </div>

    <!-- Win screen -->
    <div id="winScreen" class="hidden text-center">
      <div class="text-7xl mb-3">🏆</div>
      <h2 class="text-3xl font-black mb-2">You did it!</h2>
      <div class="text-slate-600 mb-6">
        <div>Time: <span id="finalTime" class="font-bold">0:00</span></div>
        <div>Moves: <span id="finalMoves" class="font-bold">0</span></div>
      </div>
      <div class="flex gap-3">
        <button id="playAgainBtn" class="flex-1 py-3 rounded-2xl font-bold bg-gradient-to-r from-violet-500 to-purple-600 text-white shadow-lg active:scale-95 transition">
          🔄 Play Again
        </button>
        <button id="changeBtn" class="flex-1 py-3 rounded-2xl font-bold bg-slate-200 text-slate-700 active:scale-95 transition">
          ⚙️ Settings
        </button>
      </div>
    </div>
  </div>

  <section class="max-w-2xl mx-auto mt-16 prose prose-slate">
    <h2 class="text-2xl font-bold mb-4">How to Play</h2>
    <ol class="space-y-2 text-slate-700">
      <li>Click any card to flip it.</li>
      <li>Find the matching pair: an equation card and its answer card.</li>
      <li>If the cards match, they stay flipped. If not, they flip back.</li>
      <li>Match all pairs to win!</li>
    </ol>
    <h2 class="text-2xl font-bold mt-8 mb-4">Educational Benefits</h2>
    <ul class="space-y-2 text-slate-700">
      <li><strong>Memory training:</strong> Improves working memory and concentration.</li>
      <li><strong>Math fluency:</strong> Practice mental calculation in a fun way.</li>
      <li><strong>Pattern recognition:</strong> Develops cognitive skills.</li>
      <li><strong>Stress-free learning:</strong> No pressure, just fun.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const setupScreen = document.getElementById('setupScreen');
  const gameScreen = document.getElementById('gameScreen');
  const winScreen = document.getElementById('winScreen');
  const startBtn = document.getElementById('startBtn');
  const playAgainBtn = document.getElementById('playAgainBtn');
  const changeBtn = document.getElementById('changeBtn');
  const restartBtn = document.getElementById('restartBtn');
  const board = document.getElementById('board');
  const movesEl = document.getElementById('moves');
  const matchedEl = document.getElementById('matched');
  const totalPairsEl = document.getElementById('totalPairs');
  const timerEl = document.getElementById('timer');
  const finalTime = document.getElementById('finalTime');
  const finalMoves = document.getElementById('finalMoves');

  let pairCount = 6;
  let cards: { id: number; pairId: number; text: string; matched: boolean }[] = [];
  let flipped: number[] = [];
  let moves = 0;
  let matchedPairs = 0;
  let startTime = 0;
  let timerId: number | null = null;
  let processing = false;

  function beep(freq: number, dur = 0.08, type: OscillatorType = 'sine') {
    try {
      const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = type;
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.1, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
      osc.connect(gain); gain.connect(ctx.destination);
      osc.start(); osc.stop(ctx.currentTime + dur);
    } catch (e) {}
  }

  function rand(min: number, max: number): number {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  function getOps(): string[] {
    const cbs = document.querySelectorAll('.op-cb:checked') as NodeListOf<HTMLInputElement>;
    const ops = Array.from(cbs).map(cb => cb.value);
    return ops.length > 0 ? ops : ['+'];
  }

  function genPair(usedAnswers: Set<number>, ops: string[]): { eq: string; ans: number } | null {
    for (let attempt = 0; attempt < 50; attempt++) {
      const op = ops[rand(0, ops.length - 1)];
      let a: number, b: number, ans: number, eq: string;
      if (op === '+') {
        a = rand(1, 12); b = rand(1, 12);
        ans = a + b; eq = `${a} + ${b}`;
      } else if (op === '-') {
        a = rand(2, 15); b = rand(1, a - 1);
        ans = a - b; eq = `${a} − ${b}`;
      } else if (op === '*') {
        a = rand(2, 9); b = rand(2, 9);
        ans = a * b; eq = `${a} × ${b}`;
      } else {
        ans = rand(2, 9); b = rand(2, 9);
        a = ans * b; eq = `${a} ÷ ${b}`;
      }
      if (!usedAnswers.has(ans)) {
        usedAnswers.add(ans);
        return { eq, ans };
      }
    }
    return null;
  }

  function buildBoard() {
    const ops = getOps();
    const usedAnswers = new Set<number>();
    const pairs: { eq: string; ans: number }[] = [];
    for (let i = 0; i < pairCount; i++) {
      const p = genPair(usedAnswers, ops);
      if (p) pairs.push(p);
    }

    cards = [];
    pairs.forEach((p, i) => {
      cards.push({ id: cards.length, pairId: i, text: p.eq, matched: false });
      cards.push({ id: cards.length, pairId: i, text: String(p.ans), matched: false });
    });

    // Shuffle
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }

    flipped = [];
    moves = 0;
    matchedPairs = 0;
    processing = false;
    if (movesEl) movesEl.textContent = '0';
    if (matchedEl) matchedEl.textContent = '0';
    if (totalPairsEl) totalPairsEl.textContent = String(pairCount);

    renderBoard();

    if (timerId) clearInterval(timerId);
    startTime = Date.now();
    timerId = window.setInterval(updateTimer, 1000);
  }

  function updateTimer() {
    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    const m = Math.floor(elapsed / 60);
    const s = elapsed % 60;
    if (timerEl) timerEl.textContent = `${m}:${String(s).padStart(2, '0')}`;
  }

  function renderBoard() {
    if (!board) return;
    // Adjust grid columns based on pair count
    const cols = pairCount <= 6 ? 3 : pairCount <= 8 ? 4 : 4;
    board.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;

    board.innerHTML = '';
    cards.forEach(card => {
      const div = document.createElement('div');
      const isFlipped = flipped.includes(card.id) || card.matched;
      div.className = 'aspect-square cursor-pointer';
      div.style.perspective = '600px';
      div.innerHTML = `
        <div class="card-inner relative w-full h-full transition-transform duration-500" style="transform-style: preserve-3d; ${isFlipped ? 'transform: rotateY(180deg);' : ''}">
          <div class="card-back absolute inset-0 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-white text-3xl shadow" style="backface-visibility: hidden; -webkit-backface-visibility: hidden;">
            ?
          </div>
          <div class="card-front absolute inset-0 rounded-xl ${card.matched ? 'bg-gradient-to-br from-green-400 to-emerald-500 text-white' : 'bg-white border-2 border-violet-300 text-slate-800'} flex items-center justify-center font-bold text-xl md:text-2xl shadow" style="backface-visibility: hidden; -webkit-backface-visibility: hidden; transform: rotateY(180deg);">
            ${card.text}
          </div>
        </div>
      `;
      div.addEventListener('click', () => flipCard(card.id));
      board?.appendChild(div);
    });
  }

  function flipCard(id: number) {
    if (processing) return;
    const card = cards.find(c => c.id === id);
    if (!card || card.matched) return;
    if (flipped.includes(id)) return;
    if (flipped.length >= 2) return;

    beep(500, 0.05);
    flipped.push(id);
    renderBoard();

    if (flipped.length === 2) {
      moves++;
      if (movesEl) movesEl.textContent = String(moves);
      processing = true;

      const c1 = cards.find(c => c.id === flipped[0])!;
      const c2 = cards.find(c => c.id === flipped[1])!;

      if (c1.pairId === c2.pairId) {
        // Match!
        setTimeout(() => {
          c1.matched = true;
          c2.matched = true;
          matchedPairs++;
          if (matchedEl) matchedEl.textContent = String(matchedPairs);
          flipped = [];
          processing = false;
          beep(880, 0.1);
          setTimeout(() => beep(1100, 0.15), 80);
          renderBoard();

          if (matchedPairs === pairCount) {
            setTimeout(showWin, 600);
          }
        }, 400);
      } else {
        // No match
        setTimeout(() => {
          flipped = [];
          processing = false;
          beep(220, 0.15, 'sawtooth');
          renderBoard();
        }, 1000);
      }
    }
  }

  function showWin() {
    if (timerId) clearInterval(timerId);
    [523, 659, 784, 1046, 1318].forEach((f, i) => setTimeout(() => beep(f, 0.2), i * 100));
    if (finalTime && timerEl) finalTime.textContent = timerEl.textContent || '0:00';
    if (finalMoves) finalMoves.textContent = String(moves);
    gameScreen?.classList.add('hidden');
    winScreen?.classList.remove('hidden');
  }

  function startGame() {
    setupScreen?.classList.add('hidden');
    winScreen?.classList.add('hidden');
    gameScreen?.classList.remove('hidden');
    buildBoard();
  }

  function showSetup() {
    setupScreen?.classList.remove('hidden');
    gameScreen?.classList.add('hidden');
    winScreen?.classList.add('hidden');
    if (timerId) clearInterval(timerId);
  }

  document.querySelectorAll('.diff-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.diff-btn').forEach(b => {
        b.removeAttribute('data-active');
        b.classList.remove('border-violet-500', 'bg-violet-50');
      });
      btn.setAttribute('data-active', 'true');
      btn.classList.add('border-violet-500', 'bg-violet-50');
      pairCount = parseInt((btn as HTMLElement).dataset.pairs || '6');
    });
  });

  document.querySelector('.diff-btn[data-active="true"]')?.classList.add('border-violet-500', 'bg-violet-50');

  startBtn?.addEventListener('click', startGame);
  playAgainBtn?.addEventListener('click', startGame);
  restartBtn?.addEventListener('click', startGame);
  changeBtn?.addEventListener('click', showSetup);
</script>
