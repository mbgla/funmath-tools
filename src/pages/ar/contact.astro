---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Contact — FunMath Tools';
const description = 'Get in touch with FunMath Tools. Send feedback, suggestions, or report bugs.';
---

<BaseLayout title={title} description={description}>
  <div class="max-w-2xl mx-auto py-8">
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2">/</span>
      <span>Contact</span>
    </nav>

    <div class="text-center mb-10">
      <div class="inline-flex w-20 h-20 rounded-3xl bg-gradient-to-br from-green-400 to-teal-600 items-center justify-center text-5xl mb-4">📧</div>
      <h1 class="text-4xl font-extrabold text-slate-900 mb-3">Contact Us</h1>
      <p class="text-slate-600">We'd love to hear from you!</p>
    </div>

    <div class="bg-white rounded-3xl shadow-xl p-8">
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-blue-50 rounded-2xl p-6 text-center">
          <div class="text-4xl mb-2">📧</div>
          <h3 class="font-bold mb-1">Email Us</h3>
          <a href="mailto:contact@funmath.tools" class="text-brand-500 hover:underline font-semibold">
            contact@funmath.tools
          </a>
        </div>

        <div class="bg-purple-50 rounded-2xl p-6 text-center">
          <div class="text-4xl mb-2">💡</div>
          <h3 class="font-bold mb-1">Suggestions</h3>
          <p class="text-sm text-slate-600">Have a game idea? Tell us!</p>
        </div>
      </div>

      <h2 class="text-xl font-bold mb-3">What to Contact Us About</h2>
      <ul class="space-y-3 text-slate-700 mb-6">
        <li class="flex items-start gap-3">
          <span class="text-2xl">🐛</span>
          <div>
            <strong>Bug Reports:</strong> Found something broken? Let us know!
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-2xl">💡</span>
          <div>
            <strong>Feature Requests:</strong> Suggest new tools or games.
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-2xl">🤝</span>
          <div>
            <strong>Partnerships:</strong> Schools, organizations, or collaborations.
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-2xl">📝</span>
          <div>
            <strong>Feedback:</strong> Tell us how we can improve.
          </div>
        </li>
      </ul>

      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800">
        <strong>📬 Response time:</strong> We typically respond within 24-48 hours.
      </div>
    </div>
  </div>
</BaseLayout>
