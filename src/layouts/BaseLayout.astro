---
// src/layouts/BaseLayout.astro
import { getLangFromUrl, useTranslations, languages, getLocalizedPath, type Language } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  pageKey?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { 
  title = t('site.title' as any),
  description = t('site.description' as any),
} = Astro.props;

const dir = lang === 'ar' ? 'rtl' : 'ltr';
const fontClass = lang === 'ar' ? 'font-arabic' : 'font-sans';

// Strip locale prefix to get "bare" path (for language switcher)
const currentPath = Astro.url.pathname.replace(/^\/(ar|fr)/, '') || '/';
---

<!doctype html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  
  <!-- Alternate language links for SEO -->
  {Object.keys(languages).map(l => (
    <link 
      rel="alternate" 
      hreflang={l} 
      href={`${Astro.site}${l === 'en' ? '' : l + '/'}${currentPath.slice(1)}`} 
    />
  ))}
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link 
    rel="stylesheet" 
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cairo:wght@400;600;700;800&display=swap" 
  />
  
  <!-- Google AdSense (uncomment after approval) -->
  <!--
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  -->
</head>

<body class={`${fontClass} bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen text-slate-800`}>
  
  <!-- Header -->
  <header class="bg-white/90 backdrop-blur-sm border-b border-slate-200 sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 font-bold text-xl text-brand-700 hover:text-brand-500 transition">
        <span class="text-2xl">🧮</span>
        <span>FunMath</span>
      </a>
      
      <nav class="flex items-center gap-4">
        <a href={getLocalizedPath('/', lang)} class="text-sm font-medium text-slate-600 hover:text-brand-500 transition">
          {t('nav.home' as any)}
        </a>
        
        <!-- Language Switcher -->
        <div class="flex items-center gap-1 bg-slate-100 rounded-full p-1">
          {Object.entries(languages).map(([code, name]) => (
            <a 
              href={code === 'en' ? currentPath : `/${code}${currentPath}`}
              class:list={[
                'px-3 py-1 text-xs font-bold rounded-full transition',
                lang === code ? 'bg-brand-500 text-white' : 'text-slate-600 hover:bg-slate-200'
              ]}
              aria-label={`Switch to ${name}`}
            >
              {code.toUpperCase()}
            </a>
          ))}
        </div>
      </nav>
    </div>
  </header>
  
  <!-- Main -->
  <main class="max-w-6xl mx-auto px-4 py-8">
    <slot />
  </main>
  
  <!-- Footer -->
  <footer class="border-t border-slate-200 mt-16 py-10 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
        <!-- Brand -->
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center text-white text-sm font-black">F</div>
            <span class="font-extrabold text-slate-900">FunMath Tools</span>
          </div>
          <p class="text-sm text-slate-600">Free interactive math tools and games for everyone.</p>
        </div>

        <!-- Tools -->
        <div>
          <h3 class="font-bold text-slate-800 mb-3 text-sm">Tools</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/tools/random-number" class="text-slate-600 hover:text-brand-500">Random Number</a></li>
            <li><a href="/tools/dice" class="text-slate-600 hover:text-brand-500">Dice Roller</a></li>
            <li><a href="/tools/coin-flip" class="text-slate-600 hover:text-brand-500">Coin Flip</a></li>
            <li><a href="/tools/stopwatch" class="text-slate-600 hover:text-brand-500">Stopwatch</a></li>
            <li><a href="/#tools" class="text-brand-500 hover:underline font-semibold">View all →</a></li>
          </ul>
        </div>

        <!-- Games -->
        <div>
          <h3 class="font-bold text-slate-800 mb-3 text-sm">Games</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/games/quick-math" class="text-slate-600 hover:text-brand-500">Quick Math</a></li>
            <li><a href="/games/2048-math" class="text-slate-600 hover:text-brand-500">2048 Math</a></li>
            <li><a href="/games/tug-of-war" class="text-slate-600 hover:text-brand-500">Tug of War</a></li>
            <li><a href="/games/math-snake" class="text-slate-600 hover:text-brand-500">Math Snake</a></li>
            <li><a href="/#games" class="text-brand-500 hover:underline font-semibold">View all →</a></li>
          </ul>
        </div>

        <!-- Site -->
        <div>
          <h3 class="font-bold text-slate-800 mb-3 text-sm">Site</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/about" class="text-slate-600 hover:text-brand-500">About</a></li>
            <li><a href="/contact" class="text-slate-600 hover:text-brand-500">Contact</a></li>
            <li><a href="/privacy" class="text-slate-600 hover:text-brand-500">Privacy Policy</a></li>
            <li><a href="/terms" class="text-slate-600 hover:text-brand-500">Terms of Service</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-slate-200 pt-6 flex flex-col md:flex-row justify-between items-center gap-2 text-sm text-slate-500">
        <p>{t('common.footer' as any)}</p>
        <p>Made with ❤️ for teachers, students & parents</p>
      </div>
    </div>
  </footer>
  
</body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  /* Numbers always LTR even in Arabic */
  input[type="number"],
  .tabular-nums,
  [class*="font-mono"] {
    direction: ltr;
    text-align: center;
  }
  /* Better Arabic font stack */
  html[lang="ar"] body {
    font-family: 'Cairo', 'Tajawal', 'Segoe UI', system-ui, sans-serif;
  }
</style>
