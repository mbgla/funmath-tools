---
// src/layouts/BaseLayout.astro
import { getLangFromUrl, useTranslations, languages, getLocalizedPath, type Language } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  pageKey?: string;
  textContent?: boolean; // true = allow RTL text (for about/privacy pages)
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { 
  title = t('site.title' as any),
  description = t('site.description' as any),
  textContent = false,
} = Astro.props;

const dir = lang === 'ar' ? 'rtl' : 'ltr';
const fontClass = lang === 'ar' ? 'font-arabic' : 'font-sans';
// Main content dir: always LTR for games/tools, RTL only for text pages in Arabic
const mainDir = (lang === 'ar' && textContent) ? 'rtl' : 'ltr';

// Strip locale prefix to get "bare" path (for language switcher)
const currentPath = Astro.url.pathname.replace(/^\/(ar|fr)/, '') || '/';
---

<!doctype html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  
  <!-- Alternate language links for SEO -->
  {Object.keys(languages).map(l => (
    <link 
      rel="alternate" 
      hreflang={l} 
      href={`${Astro.site}${l === 'en' ? '' : l + '/'}${currentPath.slice(1)}`} 
    />
  ))}
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link 
    rel="stylesheet" 
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cairo:wght@400;600;700;800&display=swap" 
  />
  
  <!-- Google AdSense (uncomment after approval) -->
  <!--
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  -->

