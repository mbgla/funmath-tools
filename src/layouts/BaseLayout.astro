        ttt_correct: '✓ Correct!', ttt_wrong: '✗ C\'était',
      },
    };
    // Shorthand helper
    window._t = function(key) {
      return (window.__T__[window.__LANG__] || window.__T__.en)[key] || window.__T__.en[key] || key;
    };
    // Auto-translate elements with data-i18n attribute
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        var translated = window._t(key);
        if (translated && translated !== key) el.textContent = translated;
      });
    });
  </script>
</head>

<body class={`${fontClass} bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen text-slate-800`}>
  
  <!-- Header -->
  <header class="bg-white/90 backdrop-blur-sm border-b border-slate-200 sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 font-bold text-xl text-brand-700 hover:text-brand-500 transition">
        <span class="text-2xl">🧮</span>
        <span>FunMath</span>
      </a>
      
      <nav class="flex items-center gap-4">
        <a href={getLocalizedPath('/', lang)} class="text-sm font-medium text-slate-600 hover:text-brand-500 transition">
          {t('nav.home' as any)}
        </a>
        
        <!-- Language Switcher -->
        <div class="flex items-center gap-1 bg-slate-100 rounded-full p-1">
          {Object.entries(languages).map(([code, name]) => (
            <a 
              href={code === 'en' ? currentPath : `/${code}${currentPath}`}
              class:list={[
                'px-3 py-1 text-xs font-bold rounded-full transition',
                lang === code ? 'bg-brand-500 text-white' : 'text-slate-600 hover:bg-slate-200'
              ]}
              aria-label={`Switch to ${name}`}
            >
              {code.toUpperCase()}
            </a>
          ))}
        </div>
      </nav>
    </div>
  </header>
  
  <!-- Main -->
  <main class="max-w-6xl mx-auto px-4 py-8" dir={mainDir}>
    <slot />
  </main>
  
  <!-- Footer -->
  <footer class="border-t border-slate-200 mt-16 py-10 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
        <!-- Brand -->
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center text-white text-sm font-black">F</div>
            <span class="font-extrabold text-slate-900">FunMath Tools</span>
          </div>
          <p class="text-sm text-slate-600">{t('footer.tagline' as any)}</p>
        </div>

        <!-- Tools -->
        <div>
          <h3 class="font-bold text-slate-800 mb-3 text-sm">{t('footer.tools' as any)}</h3>
          <ul class="space-y-2 text-sm">
            <li><a href={getLocalizedPath('/tools/random-number', lang)} class="text-slate-600 hover:text-brand-500">{t('tool.random-number.name' as any)}</a></li>
            <li><a href={getLocalizedPath('/tools/dice', lang)} class="text-slate-600 hover:text-brand-500">{t('tool.dice.name' as any)}</a></li>
            <li><a href={getLocalizedPath('/tools/coin-flip', lang)} class="text-slate-600 hover:text-brand-500">{t('tool.coin-flip.name' as any)}</a></li>
            <li><a href={getLocalizedPath('/tools/stopwatch', lang)} class="text-slate-600 hover:text-brand-500">{t('tool.stopwatch.name' as any)}</a></li>
            <li><a href={getLocalizedPath('/', lang) + '#tools'} class="text-brand-500 hover:underline font-semibold">{t('footer.viewall' as any)}</a></li>
          </ul>
        </div>

        <!-- Games -->
        <div>
          <h3 class="font-bold text-slate-800 mb-3 text-sm">{t('footer.games' as any)}</h3>
          <ul class="space-y-2 text-sm">
            <li><a href={getLocalizedPath('/games/quick-math', lang)} class="text-slate-600 hover:text-brand-500">Quick Math</a></li>
            <li><a href={getLocalizedPath('/games/2048-math', lang)} class="text-slate-600 hover:text-brand-500">2048 Math</a></li>
            <li><a href={getLocalizedPath('/games/tug-of-war', lang)} class="text-slate-600 hover:text-brand-500">Tug of War</a></li>
            <li><a href={getLocalizedPath('/games/math-snake', lang)} class="text-slate-600 hover:text-brand-500">Math Snake</a></li>
            <li><a href={getLocalizedPath('/', lang) + '#games'} class="text-brand-500 hover:underline font-semibold">{t('footer.viewall' as any)}</a></li>
          </ul>
        </div>

        <!-- Site -->
        <div>
          <h3 class="font-bold text-slate-800 mb-3 text-sm">{t('footer.site' as any)}</h3>
          <ul class="space-y-2 text-sm">
            <li><a href={getLocalizedPath('/about', lang)} class="text-slate-600 hover:text-brand-500">{t('footer.about' as any)}</a></li>
            <li><a href={getLocalizedPath('/contact', lang)} class="text-slate-600 hover:text-brand-500">{t('footer.contact' as any)}</a></li>
            <li><a href={getLocalizedPath('/privacy', lang)} class="text-slate-600 hover:text-brand-500">{t('footer.privacy' as any)}</a></li>
            <li><a href={getLocalizedPath('/terms', lang)} class="text-slate-600 hover:text-brand-500">{t('footer.terms' as any)}</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-slate-200 pt-6 flex flex-col md:flex-row justify-between items-center gap-2 text-sm text-slate-500">
        <p>{t('common.footer' as any)}</p>
        <p>{t('footer.madewith' as any)}</p>
      </div>
    </div>
  </footer>
  
</body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  /* Numbers always LTR even in Arabic */
  input[type="number"],
  .tabular-nums,
  [class*="font-mono"] {
    direction: ltr;
    text-align: center;
  }
  /* Better Arabic font stack */
  html[lang="ar"] body {
    font-family: 'Cairo', 'Tajawal', 'Segoe UI', system-ui, sans-serif;
  }
</style>
